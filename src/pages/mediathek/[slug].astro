---
import Layout from '../../layouts/Layout.astro';
import TopNavBar from '../../components/TopNavBar.astro';
import FooterSection from '../../components/FooterSection.astro';
import BuyVideoButton from '../../components/BuyVideoButton.tsx';
import SanityPortableText from '../../components/SanityPortableText.tsx';
import { sanityClient } from '../../lib/sanity';
import { getSupabaseServer } from '../../lib/supabase';
import { buildPermissions } from '../../lib/permissions';

const { slug } = Astro.params;

// Fetch directly from Sanity for Mediathek (only Aufzeichnungen)
const video = await sanityClient.fetch(`*[_type == "seminar" && status == "aufzeichnung" && slug.current == $slug][0]{
  "slug": slug.current,
  title, description, moduleName, duration, price, badges, eventDate,
  "image": image.asset->url,
  "referenten": referenten[]->{
    name,
    role,
    "imageUrl": image.asset->url
  }
}`, { slug });

if (!video) {
  return Astro.redirect('/404');
}

// 1. Fetch authenticated user
const { data: authData } = await getSupabaseServer(Astro.request, Astro.cookies).auth.getUser();
const user = authData?.user || null;

let hasAccess = false;
if (user) {
  const supabase = getSupabaseServer(Astro.request, Astro.cookies);
  // Get profile
  const { data: profile } = await supabase
    .from('user_profiles')
    .select('has_membership, is_admin, is_partner')
    .eq('id', user.id)
    .single();

  // Get purchases
  const { data: purchases } = await supabase
    .from('purchases')
    .select('video_slug, created_at')
    .eq('user_id', user.id);

  const permissions = buildPermissions(profile, purchases || []);
  
  if (permissions.canAccessVideo(video.slug, video.moduleName, video.eventDate)) {
    hasAccess = true;
  }
}

---
<Layout title={`${video.title} - Mediathek`}>
  <TopNavBar />

  <main class="w-full bg-surface pt-32 pb-24 min-h-screen relative overflow-hidden">
    
    <!-- Abstract Background styling for Hero -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary-fixed-dim/10 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>

    <!-- Hero Header Textual Design -->
    <div class="max-w-6xl mx-auto px-6 lg:px-10 mb-16 mt-8 relative z-10 animate-[fadeInUp_1s_ease-out]">
        <a href="/mediathek" class="text-slate-400 hover:text-primary mb-10 inline-flex items-center gap-2 text-[11px] font-extrabold uppercase tracking-widest transition-colors">
          <span class="material-symbols-outlined text-[16px]">arrow_back</span>
          Zur Mediathek
        </a>

        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class="bg-primary/5 text-primary text-[10px] font-extrabold uppercase tracking-widest px-4 py-1.5 rounded-md border border-primary/10">{video.moduleName}</span>
          <span class="bg-slate-50 text-slate-500 text-[10px] font-bold uppercase tracking-widest px-4 py-1.5 rounded-md border border-slate-200 flex items-center gap-1">
            <span class="material-symbols-outlined text-[14px]">timer</span> {video.duration ? `${video.duration} Min.` : '90 Min.'}
          </span>
          <span class="bg-slate-50 text-slate-500 text-[10px] font-bold uppercase tracking-widest px-4 py-1.5 rounded-md border border-slate-200 flex items-center gap-1">
            <span class="material-symbols-outlined text-[14px]">play_circle</span> Online-Aufzeichnung
          </span>
        </div>
        
        <h1 class="text-4xl md:text-5xl lg:text-5xl max-w-4xl font-black font-headline text-[#05183a] leading-[1.1] md:leading-[1.1] mb-6 tracking-tight">
          {video.title}
        </h1>

        <p class="text-xl md:text-2xl font-light text-on-surface-variant max-w-3xl leading-relaxed">
          {typeof video.description === 'string' ? (
            <p className="whitespace-pre-line">{video.description}</p>
          ) : Array.isArray(video.description) ? (
            <SanityPortableText value={video.description} />
          ) : null}
        </p>
    </div>

    <!-- Video Details Content Grid -->
    <div class="max-w-6xl mx-auto px-6 lg:px-10 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 animate-[fadeInUp_1s_ease-out_0.2s_both]">
      
      <!-- Main Info & Course Materials -->
      <div class="lg:col-span-8 flex flex-col gap-10">
        <!-- Feature Image Mock -->
        <div class="w-full aspect-[21/9] rounded-3xl overflow-hidden shadow-sm relative">
          <img src={video.image} alt={video.title} class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-[#05183a]/80 to-transparent flex items-end p-8">
            <p class="text-white font-medium text-lg">Ein exklusiver Fachvortrag der AK Kommunal.</p>
          </div>
        </div>

        <div class="prose prose-lg prose-blue max-w-none text-on-surface-variant font-light leading-relaxed mb-4">
          <h2 class="text-2xl font-bold font-headline text-primary mt-0 mb-4 tracking-tight">Darum geht es im Seminar</h2>
          <p>Dieses Video ist Teil des <strong>{video.moduleName}s</strong> der Akademie der AK Kommunal. Die Aufzeichnung steht Ihnen samt aller Unterlagen nach dem Kauf in Ihrem persönlichen Kunden-Log-in-Bereich zur Verfügung.</p>
          
          <p class="mt-6">Das Seminar richtet sich primär an Kämmerer, Fachbereichsleiter Finanzen und Spezialisten aus der Verwaltung, die bereits Grundlagenwissen mitbringen und sich gezielt auf neue Gesetzeslagen oder Fachvorgaben vorbereiten müssen.</p>
        </div>

        {video.referenten && video.referenten.length > 0 && (
          <div class="mb-4">
            <h2 class="text-xl font-bold font-headline text-primary mb-6 tracking-tight">Ihre Referenten</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {video.referenten.map((speaker: any) => (
                <div class="flex items-center gap-5 p-5 rounded-2xl bg-surface border border-outline-variant/30 hover:border-primary/20 hover:shadow-sm transition-all duration-300">
                  <div class="w-16 h-16 rounded-full overflow-hidden bg-primary/5 flex-shrink-0 border border-outline-variant/20 shadow-sm">
                    {speaker.imageUrl ? (
                      <img src={speaker.imageUrl} alt={speaker.name} class="w-full h-full object-cover" />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined text-[28px]">person</span>
                      </div>
                    )}
                  </div>
                  <div class="flex flex-col">
                    <span class="text-base font-extrabold text-primary font-headline tracking-tight leading-tight">{speaker.name}</span>
                    <span class="text-xs font-bold text-primary-fixed-dim tracking-wide mt-1">{speaker.role}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Seminar Materials Callout -->
        <div class="bg-primary/5 border border-primary/10 rounded-3xl p-8 flex flex-col md:flex-row gap-8 items-start">
           <div class="w-16 h-16 bg-white rounded-2xl shadow-sm border border-outline-variant/20 flex flex-shrink-0 items-center justify-center">
             <span class="material-symbols-outlined text-primary text-[32px]">folder_copy</span>
           </div>
           <div>
             <h3 class="text-xl font-bold font-headline text-primary mb-2">Inklusive Kursunterlagen (PDF)</h3>
             <p class="text-sm leading-relaxed text-on-surface-variant">Neben der Video-Aufzeichnung erhalten Sie vollen Zugriff auf die begleitenden Skripte, Präsentationsfolien und Praxishilfen als PDF-Downloads in Ihrem persönlichen Dashboard-Bereich.</p>
           </div>
        </div>
      </div>

      <!-- Sidebar / Buy Box -->
      <div class="lg:col-span-4 relative">
        <!-- Sticky Container -->
        <div class="sticky top-32 bg-white p-8 rounded-3xl border border-slate-200 shadow-xl flex flex-col">
          <h3 class="text-2xl font-black font-headline text-[#05183a] mb-2">Seminar-Zugang</h3>
          <p class="text-sm text-slate-500 mb-8 font-light">Nach dem Erwerb erscheint das Video automatisch in Ihrer persönlichen Lernwelt.</p>
          
          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-4 pb-4 border-b border-slate-100">
              <span class="material-symbols-outlined text-[#3b82f6] text-[24px] mt-0.5">smart_display</span>
              <div>
                <strong class="text-[13px] text-[#05183a] uppercase tracking-wider block mb-1">Video auf Abruf</strong>
                <span class="text-[15px] font-medium text-slate-600 block">Im Kundenbereich streambar</span>
              </div>
            </div>
            <div class="flex items-start gap-4 pb-2">
              <span class="material-symbols-outlined text-[#3b82f6] text-[24px] mt-0.5">download</span>
              <div>
                <strong class="text-[13px] text-[#05183a] uppercase tracking-wider block mb-1">Download-Materialien</strong>
                <span class="text-[15px] font-medium text-slate-600 block">Präsentationen & PDFs inklusive</span>
              </div>
            </div>
          </div>
          
          {hasAccess ? (
            <div class="bg-emerald-50 rounded-xl p-6 mb-6 border border-emerald-100 flex flex-col items-center justify-center text-center gap-3">
              <div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center">
                 <span class="material-symbols-outlined text-[24px]">check_circle</span>
              </div>
              <div class="mb-2">
                <span class="block text-[10px] uppercase font-bold tracking-widest text-emerald-600 mb-1">Bereits Freigeschaltet</span>
                <span class="text-sm font-medium text-emerald-800">Sie haben vollen Zugriff auf dieses Seminar!</span>
              </div>
              <a href={`/app/player/${video.slug}`} class="w-full bg-emerald-600 hover:bg-emerald-700 text-white text-[15px] font-bold py-4 px-4 rounded-xl transition-all shadow-sm flex items-center justify-center gap-2">
                Jetzt ansehen <span class="material-symbols-outlined text-[20px]">play_arrow</span>
              </a>
            </div>
          ) : (
            <div class="flex flex-col">
              <div class="flex items-end justify-between mb-8">
                <span class="block text-[11px] uppercase font-bold tracking-[0.2em] text-slate-400">Preis</span>
                <span class="text-4xl font-black text-[#05183a] leading-none">{video.price} €</span>
              </div>

              <!-- Connecting to SideCart -->
              <BuyVideoButton client:load video={{ id: video.slug, title: video.title, price: video.price || 0 }} />

              <p class="text-center text-[10px] text-slate-400 uppercase mt-5 font-bold tracking-widest">
                Oder <a href={`/login?redirect=/mediathek/${video.slug}`} class="text-[#3b82f6] hover:underline">Einloggen</a>
              </p>
            </div>
          )}
        </div>
      </div>

    </div>
  </main>

  <FooterSection />
</Layout>
