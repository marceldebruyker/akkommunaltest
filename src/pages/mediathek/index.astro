---
import Layout from '../../layouts/Layout.astro';
import TopNavBar from '../../components/TopNavBar.astro';
import FooterSection from '../../components/FooterSection.astro';
import AcademyFocusSection from '../../components/AcademyFocusSection.astro';
import { sanityClient } from '../../lib/sanity';

const rawVideos = await sanityClient.fetch(`*[_type == "seminar" && status == "aufzeichnung"]{
  "slug": slug.current,
  title, duration, price, badges, moduleName,
  "topics": coalesce(topics, [topic]),
  "referenten": referenten[]->{ name, role, "imageUrl": image.asset->url }
}`);

function getModuleId(moduleName: string) {
  const name = (moduleName || '').toLowerCase();
  if (name.includes('grundlagen')) return 'grundlagen';
  if (name.includes('spezialthemen')) return 'spezialthemen';
  if (name.includes('praktiker')) return 'praktiker';
  return 'all';
}
---

<Layout title="Videothek - AK Kommunal">
  <TopNavBar />
  
  <main class="w-full bg-surface pt-32 pb-24 min-h-screen relative overflow-hidden">
    <!-- Abstract Background styling -->
    <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-primary/5 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
    
    <!-- Header -->
    <div class="max-w-6xl mx-auto px-6 lg:px-10 mb-12 relative z-10 animate-[fadeInUp_1s_ease-out]">
      <div class="flex items-center gap-4 mb-4">
        <div class="h-[2px] w-12 bg-primary"></div>
        <h2 class="text-[10px] md:text-xs font-bold text-primary tracking-widest uppercase">
          AK Kommunal Akademie
        </h2>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold font-headline text-primary tracking-tight leading-[1.1] pb-2 mb-6 max-w-3xl">
        Unsere Videothek für<br/> <span class="text-primary-fixed-dim">kommunale Fachexpertise.</span>
      </h1>
      <p class="text-lg font-body leading-relaxed font-light text-on-surface-variant max-w-2xl">
        Fortbildung auf höchstem Niveau. Entdecken Sie praxisnahe Online-Kurse und Experten-Aufzeichnungen speziell für die Anforderungen der öffentlichen Verwaltung.
      </p>
    </div>

    <!-- Main Content Grid -->
    <div class="max-w-6xl mx-auto px-6 lg:px-10 pb-32">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
        
        <!-- Sidebar Filters -->
        <aside class="w-full lg:w-48 flex-shrink-0">
          <!-- Modul Filter -->
          <div class="mb-10">
            <h3 class="text-[9px] font-bold text-on-surface-variant uppercase tracking-[0.2em] mb-5">Nach Modul</h3>
            <div class="space-y-4">
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="modul" value="all" class="filter-radio module-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" checked />
                <span class="text-[13px] font-medium text-[#05183a] group-hover:text-primary transition-colors">Alle Module</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="modul" value="grundlagen" class="filter-radio module-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Grundlagen</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="modul" value="spezialthemen" class="filter-radio module-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Spezialthemen</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="modul" value="praktiker" class="filter-radio module-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Praktiker</span>
              </label>
            </div>
          </div>
          
          <!-- Themen Filter -->
          <div class="mb-10">
            <h3 class="text-[9px] font-bold text-on-surface-variant uppercase tracking-[0.2em] mb-5">Nach Thema</h3>
            <div class="space-y-4">
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="thema" value="all" class="filter-radio topic-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" checked />
                <span class="text-[13px] font-medium text-[#05183a] group-hover:text-primary transition-colors">Alle Themen</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="thema" value="umsatzsteuer" class="filter-radio topic-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Umsatzsteuer & § 2b UStG</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="thema" value="ertragsteuern" class="filter-radio topic-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Ertragsteuern</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="thema" value="tax-cms" class="filter-radio topic-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Tax CMS</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="thema" value="rechnungswesen" class="filter-radio topic-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Jahresabs. & Rechnungsw.</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="thema" value="energie" class="filter-radio topic-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Energie & Nachhaltigkeit</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="thema" value="it-security" class="filter-radio topic-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">IT & Datensicherheit</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="thema" value="aktuelles" class="filter-radio topic-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Aktuelles & Updates</span>
              </label>
            </div>
          </div>


        </aside>

        <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-x-6 gap-y-6" id="video-list">
          {rawVideos.map((video: any) => (
            <a href={`/mediathek/${video.slug}`} class="video-card group relative flex flex-col p-7 bg-white border border-slate-200 rounded-3xl hover:border-primary/20 hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1" data-module={getModuleId(video.moduleName)} data-topics={(video.topics || ['umsatzsteuer']).join(',')}>
              <!-- Content without Image Banner -->
              <h3 class="text-lg font-bold font-headline text-[#05183a] mb-5 leading-tight group-hover:text-primary-fixed-dim transition-colors">{video.title}</h3>
              
              {video.referenten && video.referenten.length > 0 && (
                <div class="flex flex-col gap-3 mb-6">
                  {video.referenten.map((speaker: any) => (
                    <div class="flex items-center gap-3 bg-slate-50 border border-slate-100 rounded-full py-1.5 pl-1.5 pr-4 shrink-0 transition-opacity hover:bg-slate-100">
                      <div class="w-8 h-8 rounded-full overflow-hidden bg-slate-200 border border-white shrink-0">
                        {speaker.imageUrl ? (
                           <img src={speaker.imageUrl} alt={speaker.name} class="w-full h-full object-cover grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500" />
                        ) : (
                           <div class="w-full h-full flex items-center justify-center text-slate-400">
                             <span class="material-symbols-outlined text-[16px]">person</span>
                           </div>
                        )}
                      </div>
                      <div class="flex flex-col">
                        <span class="text-[11px] font-extrabold text-[#05183a] uppercase tracking-wider leading-none">{speaker.name}</span>
                        <span class="text-[9px] font-medium text-slate-500 leading-tight mt-1">{speaker.role}</span>
                      </div>
                    </div>
                  ))}
                </div>
              )}
              
              <div class="flex items-center gap-5 text-[11px] font-medium text-[#05183a]/70 mb-6 border-b border-slate-100 pb-6">
                <div class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[14px]">schedule</span> {video.duration ? `${video.duration} Min.` : '90 Min.'}</div>
                <div class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[14px]">videocam</span> Aufzeichnung</div>
              </div>

              <!-- Price Footer -->
              <div class="flex items-end justify-between mt-auto">
                <div class="space-y-1">
                  <div class="text-[8px] uppercase font-bold text-primary tracking-[0.1em]">Mitglieder: Inklusive</div>
                  <div class="text-[11px] font-bold text-[#05183a] uppercase tracking-widest">Extern: {video.price || 0} €</div>
                </div>
                <!-- Cart Button -->
                <button class="w-9 h-9 bg-slate-50 group-hover:bg-[#05183a] border border-slate-200 group-hover:border-[#05183a] rounded-full flex items-center justify-center text-slate-400 group-hover:text-white transition-colors">
                  <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                </button>
              </div>
            </a>
          ))}
          
          {rawVideos.length === 0 && (
             <div class="col-span-1 md:col-span-2 text-center py-20 opacity-60">
                 <span class="material-symbols-outlined text-4xl mb-2">videocam_off</span>
                 <p class="font-bold text-lg text-[#05183a]">Bisher keine Aufzeichnungen verfügbar.</p>
             </div>
          )}
          <div id="empty-state" class="hidden col-span-1 md:col-span-2 text-center py-20 opacity-60">
               <span class="material-symbols-outlined text-4xl mb-2">filter_list_off</span>
               <p class="font-bold text-lg text-[#05183a]">Keine Aufzeichnung für diese Filterkombination.</p>
          </div>
        </div>

      </div>
    </div>
  </main>

  <AcademyFocusSection />
  
  <FooterSection />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const videoCards = document.querySelectorAll('.video-card');
    const emptyState = document.getElementById('empty-state');

    function updateFilters() {
      let currentModule = 'all';
      let currentTopic = 'all';
      
      const activeModuleRadio = document.querySelector('input.module-radio:checked');
      if (activeModuleRadio) currentModule = activeModuleRadio.getAttribute('value') || 'all';
      
      const activeTopicRadio = document.querySelector('input.topic-radio:checked');
      if (activeTopicRadio) currentTopic = activeTopicRadio.getAttribute('value') || 'all';
      
      // Update styling tags for active/inactive text
      document.querySelectorAll<HTMLInputElement>('input.filter-radio').forEach((r) => {
        const textSpan = r.nextElementSibling;
        if (!textSpan) return;
        
        if (r.checked || r.hasAttribute('checked')) {
          textSpan.classList.remove('font-light');
          textSpan.classList.add('font-medium');
        } else {
          textSpan.classList.add('font-light');
          textSpan.classList.remove('font-medium');
        }
      });

      let visibleCount = 0;
      videoCards.forEach(card => {
        const cardModule = card.getAttribute('data-module');
        const cardTopicsList = card.getAttribute('data-topics') || '';
        
        const moduleMatch = (currentModule === 'all' || cardModule === currentModule);
        const topicMatch = (currentTopic === 'all' || cardTopicsList.includes(currentTopic));
        
        if (moduleMatch && topicMatch) {
          card.setAttribute('style', 'display: flex;');
          card.classList.add('is-visible');
          visibleCount++;
        } else {
          card.setAttribute('style', 'display: none;');
          card.classList.remove('is-visible');
        }
      });
      
      if (emptyState) {
        if (visibleCount === 0) emptyState.classList.remove('hidden');
        else emptyState.classList.add('hidden');
      }
    }

    document.querySelectorAll('input.filter-radio').forEach(r => {
      r.addEventListener('change', updateFilters);
    });
    
    // Initial call in case browsers preserve radio state on reload
    updateFilters();
  });
</script>
