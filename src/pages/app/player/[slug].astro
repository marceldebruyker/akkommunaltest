---
import AppLayout from '../../../layouts/AppLayout.astro';
import { sanityClient } from '../../../lib/sanity';
import { getSupabaseServer } from '../../../lib/supabase';
import SanityPortableText from '../../../components/SanityPortableText.tsx';

const { slug } = Astro.params;

// 1. Authenticate user
const supabase = getSupabaseServer(Astro.request, Astro.cookies);
const { data: authData } = await supabase.auth.getUser();

if (!authData?.user) {
  return Astro.redirect('/login');
}

// 2. Fetch Seminar from Sanity
const video = await sanityClient.fetch(`*[_type == "seminar" && status == "aufzeichnung" && slug.current == $slug][0]{
  "slug": slug.current,
  title, description, moduleName, duration, vimeoId, bunnyVideoId,
  "materials": materials[].asset->{url, originalFilename},
  "imageUrl": image.asset->url
}`, { slug });

if (!video) {
  return Astro.redirect('/404');
}

// 3. Verify Purchase Access
const { data: purchaseData } = await supabase
  .from('purchases')
  .select('id')
  .eq('user_id', authData.user.id)
  .eq('video_slug', video.slug)
  .single();

if (!purchaseData) {
  // If no purchase found, redirect them to the mediathek detail page to buy it
  return Astro.redirect(`/mediathek/${video.slug}`);
}

// 4. Parse Video Input
let videoInfo = null;
if (video.bunnyVideoId) {
  videoInfo = { type: 'bunny', id: video.bunnyVideoId.trim() };
} else if (video.vimeoId) {
  const input = video.vimeoId.trim();
  const ytMatch = input.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/);
  const vimeoMatch = input.match(/(?:vimeo\.com\/|player\.vimeo\.com\/video\/)([0-9]+)/);
  
  if (ytMatch) {
    videoInfo = { type: 'youtube', id: ytMatch[1] };
  } else if (vimeoMatch) {
    videoInfo = { type: 'vimeo', id: vimeoMatch[1] };
  } else if (/^[0-9]+$/.test(input)) {
    videoInfo = { type: 'vimeo', id: input };
  }
}

---

<AppLayout title={`${video.title} - Video Player`} currentPath="/app/lernwelt">
  
  <!-- Video Player Section -->
  <div class="w-full max-w-5xl mx-auto px-0 md:px-6 mt-0 md:mt-8 mb-4 md:mb-8">
    <div class="bg-black w-full aspect-video relative flex-shrink-0 overflow-hidden md:rounded-3xl shadow-2xl shadow-[#05183a]/10 ring-1 ring-[#05183a]/5">
     {videoInfo?.type === 'bunny' ? (
       <iframe 
         src={`https://iframe.mediadelivery.net/embed/634463/${videoInfo.id}?autoplay=true&preload=true&responsive=true`}
         loading="lazy"
         class="absolute inset-0 w-full h-full"
         style="border:0;"
         allow="accelerometer;gyroscope;autoplay;encrypted-media;picture-in-picture;"
         allowfullscreen={true}>
       </iframe>
     ) : videoInfo?.type === 'youtube' ? (
       <iframe 
         src={`https://www.youtube.com/embed/${videoInfo.id}?autoplay=1&rel=0`} 
         class="absolute inset-0 w-full h-full" 
         frameborder="0" 
         allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
         allowfullscreen>
       </iframe>
     ) : videoInfo?.type === 'vimeo' ? (
       <iframe 
         src={`https://player.vimeo.com/video/${videoInfo.id}?autoplay=1&title=0&byline=0&portrait=0`} 
         class="absolute inset-0 w-full h-full" 
         frameborder="0" 
         allow="autoplay; fullscreen; picture-in-picture" 
         allowfullscreen>
       </iframe>
     ) : (
       <div class="text-white text-center flex flex-col items-center p-8 bg-[#05183a]/50 rounded-2xl border border-white/10 backdrop-blur-md">
          <span class="material-symbols-outlined text-[48px] text-white/50 mb-4">videocam_off</span>
          <p class="text-xl font-bold">Video nicht gefunden</p>
          <p class="text-white/70 text-sm mt-3 max-w-sm">Es ist kein gültiger Video-Link hinterlegt. Bitte überprüfen Sie den Link in Sanity (Bunny.net ID bevorzugt).</p>
       </div>
     )}
    </div>
  </div>

  <div class="p-8 pb-16 max-w-5xl mx-auto">
    
    <div class="flex flex-col md:flex-row md:items-start justify-between gap-8 mb-12">
      <div>
        <div class="flex items-center gap-3 mb-4">
          <span class="text-[10px] uppercase font-bold tracking-widest text-[#05183a] bg-blue-50 px-3 py-1 rounded border border-blue-100">{video.moduleName || 'Seminar'}</span>
          <span class="text-[12px] font-semibold text-gray-500 flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">schedule</span> {video.duration || '90 Min.'}</span>
        </div>
        <h1 class="text-3xl md:text-4xl font-extrabold font-headline text-[#05183a] tracking-tight leading-tight">{video.title}</h1>
      </div>

      <!-- Materials Download Dropdown / Buttons -->
      {video.materials && video.materials.length > 0 && (
         <div class="flex flex-col gap-2 flex-shrink-0 min-w-[250px]">
           <span class="text-[10px] uppercase font-bold tracking-widest text-gray-500 mb-1">Verfügbare Kursunterlagen</span>
           {video.materials.map((mat: any) => (
             <a href={`${mat.url}?dl=${mat.originalFilename}`} target="_blank" class="bg-[#05183a] text-white px-5 py-3 rounded-xl font-bold shadow-sm hover:shadow-md hover:bg-blue-900 transition-all flex items-center justify-between gap-3 group">
               <div class="flex items-center gap-2 overflow-hidden">
                 <span class="material-symbols-outlined text-[20px] text-red-400">picture_as_pdf</span> 
                 <span class="text-sm truncate w-32">{mat.originalFilename || 'Dokument laden'}</span>
               </div>
               <span class="material-symbols-outlined text-[18px] group-hover:-translate-y-0.5 transition-transform">download</span>
             </a>
           ))}
         </div>
      )}
    </div>

    <!-- Section Header -->
    <div class="border-b border-gray-200 mb-8 flex gap-8">
      <h2 class="text-sm uppercase tracking-wider font-bold text-blue-600 border-b-2 border-blue-600 pb-3 -mb-[1px]">Beschreibung</h2>
    </div>

    <div class="prose prose-lg max-w-none text-gray-600 font-light leading-relaxed">
      {typeof video.description === 'string' ? (
        <p className="whitespace-pre-line">{video.description || 'Keine weitere Beschreibung hinterlegt.'}</p>
      ) : Array.isArray(video.description) ? (
        <SanityPortableText value={video.description} />
      ) : (
        <p>Keine weitere Beschreibung hinterlegt.</p>
      )}
    </div>

  </div>
</AppLayout>

<script src="https://player.vimeo.com/api/player.js"></script>
