---
import AppLayout from '../../layouts/AppLayout.astro';
import { getSupabaseServer } from '../../lib/supabase';
import Stripe from 'stripe';
import { sanityClient } from '../../lib/sanity';
import { Resend } from 'resend';
import { createClient } from '@supabase/supabase-js';

const supabase = getSupabaseServer(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect('/login');
}

let notification = '';

const email = user.email || '';
const { data: profile } = await supabase
  .from('user_profiles')
  .select('*')
  .eq('id', user.id)
  .single();

const isAdmin = profile?.is_admin === true;
const isPartner = profile?.is_partner === true;

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const actionType = formData.get('actionType')?.toString();

    if (actionType === 'sendTeamsLink' && isAdmin) {
      const slug = formData.get('slug')?.toString();
      if (slug) {
        // Fetch all users who purchased this slug
        const supabaseAdmin = createClient(
          import.meta.env.PUBLIC_SUPABASE_URL,
          import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
          { auth: { autoRefreshToken: false, persistSession: false } }
        );
        
        const { data: purchases } = await supabaseAdmin.from('purchases').select('user_id').eq('video_slug', slug);
        if (purchases && purchases.length > 0 && process.env.RESEND_API_KEY) {
          const userIds = purchases.map(p => p.user_id);
          // Assuming user email is stored in profiles or we need auth admin fetch. 
          // Wait, 'purchases' doesn't have emails. We need to query auth.users? We can't join auth.users easily.
          // Wait, we need the emails! Let's just fetch all users from admin API and filter.
          const { data: { users: allAuthUsers } } = await supabaseAdmin.auth.admin.listUsers({ perPage: 1000 });
          const buyerEmails = allAuthUsers.filter(u => userIds.includes(u.id)).map(u => u.email).filter(Boolean) as string[];

          if (buyerEmails.length > 0) {
            const seminarDetails = await sanityClient.fetch(`*[_type == "seminar" && slug.current == $slug][0]{ title, date, msTeamsLink }`, { slug });
            const resend = new Resend(process.env.RESEND_API_KEY);
            const senderEmail = process.env.RESEND_API_KEY.includes('re_') && process.env.VERCEL_ENV !== 'production' 
              ? 'onboarding@resend.dev' 
              : 'noreply@bw-partner.de'; 

            await resend.emails.send({
              from: `AK Kommunal Plattform <${senderEmail}>`,
              to: buyerEmails,
              subject: `Einwahldaten: ${seminarDetails?.title}`,
              html: `
                <div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden;">
                  <div style="background-color: #05183a; padding: 20px; text-align: center;">
                    <h1 style="color: white; margin: 0; font-size: 20px;">AK Kommunal Plattform</h1>
                  </div>
                  <div style="padding: 30px; background-color: #ffffff;">
                    <h2 style="color: #05183a; margin-top: 0;">Ihr Zugangslink ist da!</h2>
                    <p style="color: #4b5563; line-height: 1.6;">Guten Tag,<br><br>Ihre Live-Session <strong>${seminarDetails?.title}</strong> startet bald.</p>
                    <div style="background-color: #f3f4f6; padding: 15px; border-radius: 8px; margin: 20px 0;">
                      <p style="margin: 0 0 10px 0; color: #374151;"><strong>Datum:</strong> ${seminarDetails?.date || 'Demnächst'}</p>
                      <a href="${seminarDetails?.msTeamsLink || '#'}" style="display: inline-block; background-color: #05183a; color: white; padding: 12px 24px; text-decoration: none; border-radius: 8px; font-weight: bold; margin-top: 10px;">Jetzt MS Teams beitreten</a>
                    </div>
                  </div>
                </div>
              `
            });
            notification = `Teams-Link erfolgreich an ${buyerEmails.length} Teilnehmer versendet.`;
          } else {
            notification = 'Fehler: Keine E-Mails für Käufer gefunden.';
          }
        } else {
           notification = 'Keine Käufer gefunden oder Resend API Key fehlt.';
        }
      }
    } else {
      const firstname = formData.get('firstname')?.toString() || '';
      const lastname = formData.get('lastname')?.toString() || '';
      const anrede = formData.get('anrede')?.toString() || '';
      const password = formData.get('password')?.toString();

    const jobDescription = formData.get('job_description')?.toString() || '';

    let salutationString = `${firstname} ${lastname}`;
    if (anrede === 'Herr' || anrede === 'Frau') {
      salutationString = `${anrede} ${lastname}`;
    }

    const updates: any = {
      data: {
        anrede: anrede,
        first_name: firstname,
        last_name: lastname,
        salutation_string: salutationString
      }
    };

    updates.data.job_description = jobDescription;
    const avatarFile = formData.get('avatar');
    if (avatarFile && typeof avatarFile === 'object' && avatarFile.size > 0) {
      const arrayBuffer = await avatarFile.arrayBuffer();
      const buffer = new Uint8Array(arrayBuffer);
      const filePath = `${user.id}/${Date.now()}_${avatarFile.name.replace(/[^a-zA-Z0-9.]/g, '')}`;
      
      const supabaseAdmin = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
        { auth: { autoRefreshToken: false, persistSession: false } }
      );

      const { data: uploadData, error: uploadError } = await supabaseAdmin.storage.from('avatars').upload(filePath, buffer, {
        contentType: avatarFile.type,
        upsert: true
      });

      if (uploadError) {
        console.error('Avatar upload error:', uploadError);
        notification = `Fehler beim Bild-Upload: ${uploadError.message}`;
      } else if (uploadData) {
        const { data: publicUrlData } = supabaseAdmin.storage.from('avatars').getPublicUrl(filePath);
        updates.data.avatar_url = publicUrlData.publicUrl;
      }
    }

    if (password && password.trim() !== '') {
      updates.password = password;
    }

    const { error: updateError } = await supabase.auth.updateUser(updates);

    if (updateError) {
      notification = `Fehler: ${updateError.message}`;
    } else {
      // Sync to Sanity if Partner
      if (isPartner) {
        try {
          const { sanityAdminClient } = await import('../../lib/sanityAdmin');
          const finalAvatarUrl = updates.data.avatar_url || user.user_metadata?.avatar_url;
          let sanityImageId = undefined;
          
          if (finalAvatarUrl) {
            const imgRes = await fetch(finalAvatarUrl);
            if (imgRes.ok) {
              const buffer = await imgRes.arrayBuffer();
              const asset = await sanityAdminClient.assets.upload('image', Buffer.from(buffer), { filename: `avatar-${user.id}.jpg` });
              sanityImageId = asset._id;
            }
          }
          
          const sanityDoc: any = {
            _id: `team-${user.id}`,
            _type: 'team',
            name: `${firstname} ${lastname}`.trim(),
            role: jobDescription,
            sortIndex: 99
          };
          
          if (sanityImageId) {
             sanityDoc.image = { _type: 'image', asset: { _type: 'reference', _ref: sanityImageId } };
          }
          
          await sanityAdminClient.createOrReplace(sanityDoc);
          console.log('Sanity Sync Successful');
        } catch(e) {
          console.error('[Sanity Sync Error]', e);
        }
      }

      // Fetch latest user data
      const { data: { user: updatedUser } } = await supabase.auth.getUser();
      if (updatedUser) {
        user.user_metadata = updatedUser.user_metadata;
      }
      notification = 'Änderungen erfolgreich gespeichert!';
    }
    } // Close else
  } catch (err: any) {
    notification = `Ein Fehler ist aufgetreten: ${err.message}`;
  }
}

const firstName = user.user_metadata?.first_name || '';
const lastName = user.user_metadata?.last_name || '';
const anrede = user.user_metadata?.anrede || '';
const jobDesc = user.user_metadata?.job_description || '';


// Admin Data Fetching
let adminSeminars: any[] = [];
if (isAdmin) {
  const sanityProducts = await sanityClient.fetch(`*[_type == "seminar" && status == "Live Event (Anstehend)"]{ "id": slug.current, title, date, msTeamsLink }`);
  
  const supabaseAdmin = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.SUPABASE_SERVICE_ROLE_KEY,
    { auth: { autoRefreshToken: false, persistSession: false } }
  );
  
  const { data: purchasesData } = await supabaseAdmin.from('purchases').select('video_slug');
  adminSeminars = sanityProducts.map((p: any) => {
     let count = purchasesData?.filter(pr => pr.video_slug === p.id).length || 0;
     return { ...p, participantCount: count };
  });
}

// Fetch Stripe Invoices
let userInvoices: Stripe.Invoice[] = [];
const rawStripeKey = import.meta.env.STRIPE_SECRET_KEY;
if (rawStripeKey && email) {
  const stripe = new Stripe(rawStripeKey.trim());
  try {
    console.log(`[DEBUG] Fetching customers for email: ${email}`);
    const customers = await stripe.customers.list({ email: email, limit: 3 });
    console.log(`[DEBUG] Found ${customers.data.length} customers.`);
    for (const customer of customers.data) {
      const invoices = await stripe.invoices.list({ customer: customer.id, limit: 10, status: 'paid' });
      const openInvoices = await stripe.invoices.list({ customer: customer.id, limit: 10, status: 'open' });
      userInvoices = [...userInvoices, ...invoices.data, ...openInvoices.data];
    }
    // Sort by created descending
    userInvoices.sort((a, b) => b.created - a.created);
    console.log(`[DEBUG] Found total invoices: ${userInvoices.length}`);
  } catch (err) {
    console.error(`[DEBUG] Error fetching stripe invoices:`, err);
  }
} else {
  console.log(`[DEBUG] Skipping invoice fetch. Key exists: ${!!rawStripeKey}, Email: ${email}`);
}
---

<AppLayout title="Profil & Einstellungen - AK Kommunal App" currentPath="/app/profil">
  <div class="p-8 max-w-4xl mx-auto">
    
    <div class="mb-10">
      <h1 class="text-3xl font-extrabold font-headline text-[#05183a] tracking-tight mb-2">Profil & Rechnungen</h1>
      <p class="text-gray-500">Verwalten Sie Ihre persönlichen Daten und laden Sie Buchungsbelege herunter.</p>
    </div>

    <div class="grid grid-cols-1 gap-10">
      
      {isAdmin && (
        <div class="bg-[#05183a] rounded-2xl border border-gray-800 shadow-lg p-8 relative overflow-hidden">
          <div class="absolute top-0 right-0 p-4 opacity-10">
            <span class="material-symbols-outlined text-[100px] text-white">admin_panel_settings</span>
          </div>
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-2 border-b border-gray-700 pb-4 relative z-10">
            <span class="material-symbols-outlined text-blue-400">admin_panel_settings</span> Admin-Bereich: Event Verwaltung
          </h2>
          
          <div class="grid grid-cols-1 gap-4 relative z-10">
            {adminSeminars.length === 0 ? (
              <p class="text-gray-400 text-sm">Keine anstehenden Live-Events in Sanity gefunden.</p>
            ) : adminSeminars.map((seminar) => (
              <div class="bg-white/10 border border-white/20 rounded-xl p-5 flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div>
                  <h3 class="text-white font-bold mb-1">{seminar.title}</h3>
                  <div class="flex gap-4 text-xs text-gray-300">
                    <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">calendar_today</span> {seminar.date || 'Ohne Datum'}</span>
                    <span class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">group</span> {seminar.participantCount} Anmeldungen</span>
                  </div>
                </div>
                {seminar.msTeamsLink ? (
                  <form method="POST" class="shrink-0" onsubmit="return confirm('Möchten Sie den Zugangslink jetzt wirklich an alle Teilnehmer senden? Diese Aktion kann nicht rückgängig gemacht werden.');">
                    <input type="hidden" name="actionType" value="sendTeamsLink" />
                    <input type="hidden" name="slug" value={seminar.id} />
                    <button type="submit" class="bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold py-2 px-4 rounded-lg shadow-sm transition-colors flex items-center gap-2">
                       <span class="material-symbols-outlined text-[18px]">send</span> Link an Verteiler senden
                    </button>
                  </form>
                ) : (
                  <div class="text-xs text-amber-300 font-bold bg-amber-500/10 px-3 py-2 rounded">Kein Teams-Link in Sanity</div>
                )}
              </div>
            ))}
          </div>
        </div>
      )}

      <!-- Account Settings -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
        <h2 class="text-lg font-bold text-[#05183a] mb-6 flex items-center gap-2 border-b border-gray-100 pb-4">
          <span class="material-symbols-outlined text-gray-400">tune</span> Kontoeinstellungen
        </h2>

        {notification && (
          <div class={`mb-6 p-4 rounded-xl text-sm font-semibold border ${notification.startsWith('Fehler') ? 'bg-red-50 text-red-600 border-red-200' : 'bg-emerald-50 text-emerald-700 border-emerald-200'}`}>
            {notification}
          </div>
        )}
        
        <form method="POST" id="profile-form" enctype="multipart/form-data" class="space-y-6">
          
          <!-- Avatar Upload -->
          <div class="flex items-center gap-6 border-b border-gray-100 pb-8 mb-6">
            <div class="relative w-20 h-20 rounded-full bg-[#05183a] text-white flex items-center justify-center font-bold text-xl shadow-[0_4px_14px_0_rgba(5,24,58,0.2)] overflow-hidden group">
              {user.user_metadata?.avatar_url ? (
                 <img src={user.user_metadata.avatar_url} class="w-full h-full object-cover">
              ) : (
                 <span>{firstName ? firstName.charAt(0) : email.charAt(0).toUpperCase()}{lastName ? lastName.charAt(0) : ''}</span>
              )}
              <div class="absolute inset-0 bg-black/50 hidden flex flex-col gap-1 items-center justify-center cursor-pointer group-hover:flex transition-opacity" onclick="document.getElementById('avatar-input').click()">
                <span class="material-symbols-outlined text-white text-[20px]">photo_camera</span>
              </div>
            </div>
            <div>
              <h3 class="font-bold text-[#05183a] text-[15px]">Profilbild</h3>
              <p class="text-sm text-gray-500 mt-1 max-w-xs">Klicken Sie auf Ihr Bild, um ein neues hochzuladen. Änderungen können etwas dauern.</p>
            </div>
            <input type="file" id="avatar-input" name="avatar" accept="image/jpeg, image/png, image/webp" class="hidden" onchange="document.getElementById('profile-submit-btn').click()">
          </div>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="space-y-2">
              <label class="text-xs font-bold text-gray-600 uppercase tracking-widest">Anrede</label>
              <select name="anrede" class="w-full bg-gray-50 border border-gray-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 px-4 py-2.5 rounded-lg outline-none text-sm font-medium text-[#05183a]">
                <option value="">Bitte wählen...</option>
                <option value="Frau" selected={anrede === 'Frau'}>Frau</option>
                <option value="Herr" selected={anrede === 'Herr'}>Herr</option>
                <option value="Divers" selected={anrede === 'Divers'}>Divers / Keine Angabe</option>
              </select>
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-gray-600 uppercase tracking-widest">Vorname</label>
              <input type="text" name="firstname" value={firstName} class="w-full bg-gray-50 border border-gray-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 px-4 py-2.5 rounded-lg outline-none text-sm font-medium text-[#05183a]" />
            </div>
            <div class="space-y-2">
              <label class="text-xs font-bold text-gray-600 uppercase tracking-widest">Nachname</label>
              <input type="text" name="lastname" value={lastName} class="w-full bg-gray-50 border border-gray-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 px-4 py-2.5 rounded-lg outline-none text-sm font-medium text-[#05183a]" />
            </div>
          </div>
          
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-600 uppercase tracking-widest">Berufsbezeichnung / Rolle <span class="text-gray-400 normal-case font-medium">(Optional)</span></label>
            <input type="text" name="job_description" value={jobDesc} placeholder="z.B. Steuerberater, Wirtschaftsprüfer, Bürgermeister" class="w-full bg-gray-50 border border-gray-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 px-4 py-2.5 rounded-lg outline-none text-sm font-medium text-[#05183a]" />
            {isPartner && <p class="text-xs text-blue-600 font-bold mt-1.5 flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">stars</span>Als registrierter Experte wird dieser Text im Fachportal angezeigt.</p>}
          </div>
          
          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-600 uppercase tracking-widest">E-Mail Adresse (Login)</label>
            <input type="email" name="email" value={email} readonly disabled class="w-full bg-gray-100 border border-gray-200 px-4 py-2.5 rounded-lg outline-none text-sm font-medium text-gray-500 cursor-not-allowed" title="E-Mail kann aktuell nur über den Support geändert werden" />
          </div>

          <div class="space-y-2">
            <label class="text-xs font-bold text-gray-600 uppercase tracking-widest">Neues Passwort setzen</label>
            <input type="password" name="password" placeholder="•••••••• (Leer lassen für keine Änderung)" class="w-full bg-gray-50 border border-gray-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 px-4 py-2.5 rounded-lg outline-none text-sm font-medium text-[#05183a]" />
          </div>

          <div class="pt-4 flex justify-end gap-3">
             <button type="submit" id="profile-submit-btn" class="bg-[#05183a] text-white px-6 py-2.5 rounded-xl text-sm font-bold shadow-[0_4px_14px_0_rgba(5,24,58,0.2)] hover:bg-blue-900 transition-all hover:-translate-y-0.5">
               Speichern
             </button>
          </div>
        </form>
      </div>

      <!-- Invoices -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <h2 class="text-lg font-bold text-[#05183a] m-8 mb-4 border-b border-gray-100 pb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-gray-400">receipt_long</span> Meine Rechnungen
        </h2>
        
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-gray-50 text-xs font-bold text-gray-500 uppercase tracking-wider">
              <th class="p-4 border-b border-gray-200 pl-8">Datum</th>
              <th class="p-4 border-b border-gray-200">Beschreibung</th>
              <th class="p-4 border-b border-gray-200">Betrag</th>
              <th class="p-4 border-b border-gray-200 text-right pr-8">Download</th>
            </tr>
          </thead>
          <tbody class="text-sm font-medium text-gray-700">
            {userInvoices.length === 0 ? (
               <tr>
                 <td colspan="4" class="p-8 text-center text-gray-400">Keine generierten Rechnungen gefunden.</td>
               </tr>
            ) : userInvoices.map((inv) => (
              <tr class="hover:bg-gray-50 transition-colors group">
                <td class="p-4 border-b border-gray-100 pl-8">
                  {new Date(inv.created * 1000).toLocaleDateString('de-DE')}
                </td>
                <td class="p-4 border-b border-gray-100">
                   {inv.lines.data.map(l => l.description).join(', ') || 'Fachvideo / Modul'}<br/>
                   <span class="text-xs text-gray-400 font-normal">Rechnungs-Nr: {inv.number || 'Wird generiert...'}</span>
                   {inv.status === 'open' && <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold bg-amber-100 text-amber-800">Unbezahlt</span>}
                </td>
                <td class="p-4 border-b border-gray-100 font-bold text-[#05183a]">
                  {(inv.amount_due / 100).toLocaleString('de-DE', { style: 'currency', currency: 'EUR' })}
                </td>
                <td class="p-4 border-b border-gray-100 text-right pr-8">
                  {inv.invoice_pdf ? (
                    <a href={inv.invoice_pdf} target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-lg border border-gray-200 group-hover:bg-[#05183a] group-hover:text-white group-hover:border-[#05183a] flex items-center justify-center ml-auto transition-colors text-gray-400" title="PDF Herunterladen">
                      <span class="material-symbols-outlined text-[18px]">download</span>
                    </a>
                  ) : (
                    <span class="text-xs text-gray-400 font-medium">In Bearbeitung</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

    </div>
  </div>
</AppLayout>
