---
import AppLayout from '../../layouts/AppLayout.astro';
import { getSupabaseServer } from '../../lib/supabase';
import { sanityClient, extractPlainTextFromPortableText } from '../../lib/sanity';
import { buildPermissions } from '../../lib/permissions';

const supabase = getSupabaseServer(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();

const firstName = user?.user_metadata?.first_name || user?.user_metadata?.vorname || '';
const lastName = user?.user_metadata?.last_name || user?.user_metadata?.nachname || '';
const salutationString = user?.user_metadata?.salutation_string || '';
const anrede = user?.user_metadata?.anrede || '';

let greetingName = "lieber Nutzer";
if (salutationString) {
  greetingName = salutationString;
} else if (anrede === 'Herr') {
  greetingName = `Herr ${lastName}`;
} else if (anrede === 'Frau') {
  greetingName = `Frau ${lastName}`;
} else if (firstName && lastName) {
  greetingName = `${firstName} ${lastName}`;
} else if (firstName) {
  greetingName = `${firstName}`;
} else if (lastName) {
  greetingName = `${lastName}`;
}

// Fetch real data from Sanity
const allSeminars = await sanityClient.fetch(`*[_type == "seminar" && status == "aufzeichnung"] | order(_createdAt desc) { "id": slug.current, "slug": slug.current, title, description, moduleName, duration, eventDate, "referenten": referenten[]->{ name, role, "imageUrl": image.asset->url } }`);

let permissions = buildPermissions(null, []);

if (user) {
  const { data: profile } = await supabase
    .from('user_profiles')
    .select('has_membership, is_admin, is_partner')
    .eq('id', user.id)
    .single();

  const { data: purchases } = await supabase
    .from('purchases')
    .select('video_slug')
    .eq('user_id', user.id);
  
  permissions = buildPermissions(profile, purchases || []);
}

let userSeminars = allSeminars;

if (!permissions.hasFullAccess()) {
  userSeminars = allSeminars.filter((video: any) => permissions.canAccessVideo(video.slug, video.moduleName, video.eventDate));
}

const recentSeminar = userSeminars.length > 0 ? userSeminars[0] : null;
const newSeminars = userSeminars.slice(1, 4);

const hasModuleAccess = permissions.isMember();
const ownsEverything = permissions.hasFullAccess();
const hasAnyPurchases = permissions.isMember() || userSeminars.length > 0;

    ---

<AppLayout title="Dashboard - AK Kommunal App" currentPath="/app/dashboard">
  <div class="p-8 max-w-6xl mx-auto">
    
    <!-- Greeting -->
    <div class="mb-6">
      <h1 class="text-3xl font-extrabold font-headline text-[#05183a] tracking-tight mb-2">Hallo {greetingName},</h1>
      <p class="text-gray-500">Willkommen zurück in Ihrer Zentrale.</p>
    </div>

    <!-- Upsell Banner (only for users without full access) -->
    {!ownsEverything && (
      <div class="mb-10 bg-white rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-6 shadow-[0_2px_10px_rgba(0,0,0,0.02)] border border-gray-200 relative overflow-hidden group">
        <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-[#f8981d] transition-all group-hover:w-2"></div>
        
        <div class="flex items-center gap-5 relative z-10 pl-2">
          <div class="w-12 h-12 rounded-xl bg-[#05183a]/5 flex items-center justify-center flex-shrink-0 text-[#05183a]">
            {hasAnyPurchases ? (
              <span class="material-symbols-outlined text-[24px]">workspace_premium</span>
            ) : (
              <span class="material-symbols-outlined text-[24px]">lock_open</span>
            )}
          </div>
          <div>
            {hasModuleAccess ? (
              <>
                <h3 class="text-[#05183a] font-bold text-lg mb-1">Upgrade auf das Gesamtpaket</h3>
                <p class="text-gray-500 text-sm">Sie besitzen bereits ein Fach-Modul. Erweitern Sie Ihren Account um das gesamte Portal für unbeschränkten Zugriff.</p>
              </>
            ) : hasAnyPurchases ? (
              <>
                <h3 class="text-[#05183a] font-bold text-lg mb-1">Upgrade auf ein Fach-Modul</h3>
                <p class="text-gray-500 text-sm">Sie besitzen derzeit Einzel-Seminare. Schalten Sie sich mit einem Modul-Abo den gesamten Themenbereich frei.</p>
              </>
            ) : (
              <>
                <h3 class="text-[#05183a] font-bold text-lg mb-1">Sie nutzen den kostenlosen Basis-Zugang</h3>
                <p class="text-gray-500 text-sm">Schalten Sie ein Modul frei für vollen Zugriff, oder erwerben Sie gezielt Einzelvideos in der Mediathek.</p>
              </>
            )}
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 relative z-10 flex-shrink-0 w-full md:w-auto">
          <a href="/mitglied-werden" class="text-center bg-[#05183a] hover:bg-[#0a2d6e] text-white font-bold text-sm px-6 py-3 rounded-xl transition-all shadow-sm hover:shadow whitespace-nowrap">
            Module ansehen
          </a>
          <a href="/mediathek" class="text-center bg-white border border-gray-200 hover:border-gray-300 hover:bg-gray-50 text-[#05183a] font-bold text-sm px-6 py-3 rounded-xl transition-all shadow-[0_2px_10px_rgba(0,0,0,0.02)] hover:shadow-md whitespace-nowrap">
            Zur Mediathek
          </a>
        </div>
      </div>
    )}

    {userSeminars.length === 0 ? (
      <div class="bg-gray-50 border border-gray-200 rounded-3xl p-12 text-center flex flex-col items-center">
         <div class="w-20 h-20 bg-white rounded-full shadow-sm flex items-center justify-center mb-6">
            <span class="material-symbols-outlined text-[40px] text-gray-300">movie_off</span>
         </div>
         <h2 class="text-2xl font-bold font-headline text-[#05183a] mb-2">Ihre Lernwelt ist noch leer</h2>
         <p class="text-gray-500 max-w-md mb-8">Schalten Sie sich jetzt Seminare frei oder werden Sie Mitglied, um auf exklusive Weiterbildungsinhalte zuzugreifen.</p>
         <a href="/mediathek" class="bg-[#05183a] hover:bg-[#0a2d6e] text-white font-bold py-3 px-8 rounded-xl transition-all shadow-sm">Mediathek durchstöbern</a>
      </div>
    ) : (
      <>
        <!-- Continue Learning Section -->
        {recentSeminar && (
          <div class="mb-12">
            <h2 class="text-xl font-bold text-[#05183a] mb-6 flex items-center gap-2"><span class="material-symbols-outlined text-blue-600">play_circle</span> Zuletzt hinzugefügt</h2>
            <a href={`/app/player/${recentSeminar.id}`} class="bg-white rounded-3xl border border-gray-200 shadow-sm overflow-hidden flex flex-col hover:-translate-y-1 hover:shadow-xl transition-all p-8 relative group">
              <div class="absolute right-8 top-8 opacity-0 group-hover:opacity-100 transition-opacity">
                <div class="w-10 h-10 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center">
                  <span class="material-symbols-outlined text-[20px] ml-0.5">play_arrow</span>
                </div>
              </div>
              <span class="text-[10px] uppercase font-bold text-[#05183a] tracking-widest mb-3 bg-[#05183a]/5 px-3 py-1 rounded-md border border-[#05183a]/10 w-fit">{recentSeminar.moduleName}</span>
              <h3 class="text-xl md:text-2xl font-black font-headline text-[#05183a] mb-3 leading-tight group-hover:text-blue-600 transition-colors max-w-3xl">{recentSeminar.title}</h3>
              <p class="text-sm text-gray-500 mb-8 line-clamp-2 max-w-3xl leading-relaxed">{extractPlainTextFromPortableText(recentSeminar.description)}</p>
              
              {recentSeminar.referenten && recentSeminar.referenten.length > 0 && (
                <div class="flex flex-wrap gap-4 mt-auto pt-6 border-t border-gray-100">
                  {recentSeminar.referenten.map((speaker: any) => (
                    <div class="flex items-center gap-3 bg-gray-50 border border-gray-100 rounded-full py-1.5 pl-1.5 pr-4 shrink-0 transition-opacity hover:bg-gray-100">
                      <div class="w-10 h-10 rounded-full overflow-hidden bg-gray-200 border border-white shrink-0">
                        {speaker.imageUrl ? (
                          <img src={speaker.imageUrl} alt={speaker.name} class="w-full h-full object-cover grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500" />
                        ) : (
                          <div class="w-full h-full flex items-center justify-center text-gray-400">
                            <span class="material-symbols-outlined text-[20px]">person</span>
                          </div>
                        )}
                      </div>
                      <div class="flex flex-col">
                        <span class="text-[12px] font-extrabold text-[#05183a] uppercase tracking-wider leading-none">{speaker.name}</span>
                        <span class="text-[10px] font-medium text-gray-400 leading-none mt-1">{speaker.role}</span>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </a>
          </div>
        )}

        <!-- New in your modules -->
        {newSeminars.length > 0 && (
          <div>
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-xl font-bold text-[#05183a] flex items-center gap-2"><span class="material-symbols-outlined text-emerald-500">video_library</span> Weitere Seminare in Ihrem Besitz</h2>
              <a href="/app/lernwelt" class="text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors">Alle ansehen</a>
            </div>
            <!-- Cards Grid -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              {newSeminars.map((seminar: any) => (
                <a href={`/app/player/${seminar.id}`} class="bg-white rounded-3xl border border-gray-200 shadow-sm flex flex-col hover:-translate-y-1.5 hover:shadow-xl transition-all cursor-pointer group p-6 relative">
                  <div class="absolute right-6 top-6 opacity-0 group-hover:opacity-100 transition-opacity">
                    <div class="w-8 h-8 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center">
                      <span class="material-symbols-outlined text-[16px] ml-0.5">play_arrow</span>
                    </div>
                  </div>
                  <span class="text-[9px] uppercase font-bold text-gray-500 tracking-widest block mb-2">{seminar.moduleName} • {seminar.duration ? `${seminar.duration} Min.` : '90 Min.'}</span>
                  <h4 class="font-bold font-headline text-base text-[#05183a] group-hover:text-blue-600 leading-tight mb-5 line-clamp-2 transition-colors pr-8">{seminar.title}</h4>
                  
                  {seminar.referenten && seminar.referenten.length > 0 && (
                    <div class="flex flex-col gap-3 mt-auto pt-4 border-t border-gray-100">
                      {seminar.referenten.map((speaker: any) => (
                        <div class="flex items-center gap-3">
                          <div class="w-8 h-8 rounded-full overflow-hidden bg-gray-100 border border-gray-200 shrink-0">
                            {speaker.imageUrl ? (
                               <img src={speaker.imageUrl} alt={speaker.name} class="w-full h-full object-cover grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-500" />
                            ) : (
                               <div class="w-full h-full flex items-center justify-center text-gray-400">
                                 <span class="material-symbols-outlined text-[16px]">person</span>
                               </div>
                            )}
                          </div>
                          <div class="flex flex-col">
                            <span class="text-[11px] font-bold text-[#05183a] leading-tight flex items-center gap-1">
                               {speaker.name}
                            </span>
                            <span class="text-[10px] font-medium text-gray-400 leading-tight mt-0.5">{speaker.role}</span>
                          </div>
                        </div>
                      ))}
                    </div>
                  )}
                </a>
              ))}
            </div>
          </div>
        )}
      </>
    )}

  </div>
</AppLayout>
