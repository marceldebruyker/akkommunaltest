---
import AppLayout from '../../layouts/AppLayout.astro';
import { getSupabaseServer } from '../../lib/supabase';
import { sanityClient } from '../../lib/sanity';

const supabase = getSupabaseServer(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();

const firstName = user?.user_metadata?.first_name || '';
const lastName = user?.user_metadata?.last_name || '';
const greetingName = lastName ? `Herr/Frau ${lastName}` : (firstName || 'lieber Nutzer');

// Check membership status for upsell logic
let hasMembership = false;
let purchasedSlugs: string[] = [];

if (user) {
  const { data: profile } = await supabase
    .from('user_profiles')
    .select('has_membership')
    .eq('id', user.id)
    .single();
  hasMembership = profile?.has_membership === true;

  // Fetch individual purchases
  const { data: purchases } = await supabase
    .from('purchases')
    .select('video_slug')
    .eq('user_id', user.id);
  
  if (purchases) purchasedSlugs = purchases.map(p => p.video_slug);
}

// Fetch real data from Sanity
const allSeminars = await sanityClient.fetch(`*[_type == "seminar" && status == "aufzeichnung"] | order(_createdAt desc) { "id": slug.current, "slug": slug.current, title, description, moduleName, duration, "image": image.asset->url }`);

const hasGesamtpaket = purchasedSlugs.includes('gesamtpaket') || purchasedSlugs.includes('gesamt');
let userSeminars = allSeminars;

if (!hasMembership && !hasGesamtpaket) {
  userSeminars = allSeminars.filter((video: any) => {
    if (purchasedSlugs.includes(video.slug)) return true;
    if (video.moduleName) {
      const lowerName = video.moduleName.toLowerCase();
      if (lowerName.includes('spezial') && (purchasedSlugs.includes('spezial') || purchasedSlugs.includes('spezialthemen-modul'))) return true;
      if (lowerName.includes('grundlagen') && (purchasedSlugs.includes('grundlagen') || purchasedSlugs.includes('grundlagen-modul'))) return true;
      if (lowerName.includes('praktiker') && (purchasedSlugs.includes('praktiker') || purchasedSlugs.includes('praktiker-modul'))) return true;
    }
    return false;
  });
}

const recentSeminar = userSeminars.length > 0 ? userSeminars[0] : null;
const newSeminars = userSeminars.slice(1, 4);
---

<AppLayout title="Dashboard - AK Kommunal App" currentPath="/app/dashboard">
  <div class="p-8 max-w-6xl mx-auto">
    
    <!-- Greeting -->
    <div class="mb-6">
      <h1 class="text-3xl font-extrabold font-headline text-[#05183a] tracking-tight mb-2">Hallo {greetingName},</h1>
      <p class="text-gray-500">Willkommen zurück in Ihrer Zentrale.</p>
    </div>

    <!-- Upsell Banner (only for Freemium users without active Abo) -->
    {!hasMembership && (
      <div class="mb-10 bg-white rounded-2xl p-6 md:p-8 flex flex-col md:flex-row items-center justify-between gap-6 shadow-[0_2px_10px_rgba(0,0,0,0.02)] border border-gray-200 relative overflow-hidden group">
        <div class="absolute left-0 top-0 bottom-0 w-1.5 bg-[#f8981d] transition-all group-hover:w-2"></div>
        
        <div class="flex items-center gap-5 relative z-10 pl-2">
          <div class="w-12 h-12 rounded-xl bg-[#05183a]/5 flex items-center justify-center flex-shrink-0 text-[#05183a]">
            {purchasedSlugs.length > 0 ? (
              <span class="material-symbols-outlined text-[24px]">workspace_premium</span>
            ) : (
              <span class="material-symbols-outlined text-[24px]">lock_open</span>
            )}
          </div>
          <div>
            {purchasedSlugs.length > 0 ? (
              <>
                <h3 class="text-[#05183a] font-bold text-lg mb-1">Upgrade auf ein Fach-Modul</h3>
                <p class="text-gray-500 text-sm">Sie besitzen derzeit Einzel-Seminare. Schalten Sie sich mit einem Modul-Abo den gesamten Weiterbildungskatalog bedingungslos frei.</p>
              </>
            ) : (
              <>
                <h3 class="text-[#05183a] font-bold text-lg mb-1">Sie nutzen den kostenlosen Basis-Zugang</h3>
                <p class="text-gray-500 text-sm">Schalten Sie ein Modul frei für vollen Zugriff, oder erwerben Sie gezielt Einzelvideos in der Mediathek.</p>
              </>
            )}
          </div>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 relative z-10 flex-shrink-0 w-full md:w-auto">
          <a href="/mitglied-werden" class="text-center bg-[#05183a] hover:bg-[#0a2d6e] text-white font-bold text-sm px-6 py-3 rounded-xl transition-all shadow-sm hover:shadow whitespace-nowrap">
            Module ansehen
          </a>
          <a href="/mediathek" class="text-center bg-white border border-gray-200 hover:border-gray-300 hover:bg-gray-50 text-[#05183a] font-bold text-sm px-6 py-3 rounded-xl transition-all shadow-[0_2px_10px_rgba(0,0,0,0.02)] hover:shadow-md whitespace-nowrap">
            Zur Mediathek
          </a>
        </div>
      </div>
    )}

    {userSeminars.length === 0 ? (
      <div class="bg-gray-50 border border-gray-200 rounded-3xl p-12 text-center flex flex-col items-center">
         <div class="w-20 h-20 bg-white rounded-full shadow-sm flex items-center justify-center mb-6">
            <span class="material-symbols-outlined text-[40px] text-gray-300">movie_off</span>
         </div>
         <h2 class="text-2xl font-bold font-headline text-[#05183a] mb-2">Ihre Lernwelt ist noch leer</h2>
         <p class="text-gray-500 max-w-md mb-8">Schalten Sie sich jetzt Seminare frei oder werden Sie Mitglied, um auf exklusive Weiterbildungsinhalte zuzugreifen.</p>
         <a href="/mediathek" class="bg-[#05183a] hover:bg-[#0a2d6e] text-white font-bold py-3 px-8 rounded-xl transition-all shadow-sm">Mediathek durchstöbern</a>
      </div>
    ) : (
      <>
        <!-- Continue Learning Section -->
        {recentSeminar && (
          <div class="mb-12">
            <h2 class="text-xl font-bold text-[#05183a] mb-6 flex items-center gap-2"><span class="material-symbols-outlined text-blue-600">play_circle</span> Zuletzt hinzugefügt</h2>
            <a href={`/app/player/${recentSeminar.id}`} class="bg-white rounded-3xl border border-gray-200 shadow-sm overflow-hidden flex flex-col md:flex-row group hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] transition-all">
              <div class="w-full md:w-2/5 aspect-video relative">
                <img src={recentSeminar.image || "https://images.unsplash.com/photo-1541746972996-4e0b0f43e02a?q=80&w=2070&auto=format&fit=crop"} class="w-full h-full object-cover transition-all duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-[#05183a]/80 via-[#05183a]/20 to-transparent flex items-center justify-center group-hover:bg-[#0a2d6e]/20 transition-colors">
                   <div class="w-16 h-16 rounded-full bg-white/20 backdrop-blur-md flex items-center justify-center text-white border border-white/30 transform group-hover:scale-110 shadow-lg transition-all duration-300">
                      <span class="material-symbols-outlined text-[36px] ml-1">play_arrow</span>
                   </div>
                </div>
              </div>
              <div class="p-8 flex-1 flex flex-col justify-center">
                <span class="text-[10px] uppercase font-bold text-[#05183a] tracking-widest mb-3 bg-[#05183a]/5 px-3 py-1 rounded-md border border-[#05183a]/10 w-fit">{recentSeminar.moduleName}</span>
                <h3 class="text-2xl font-bold font-headline text-[#05183a] mb-3 leading-tight group-hover:text-blue-600 transition-colors">{recentSeminar.title}</h3>
                <p class="text-sm text-gray-500 mb-6 line-clamp-2">{recentSeminar.description}</p>
                <div class="font-semibold text-blue-600 flex items-center gap-2 group-hover:gap-4 transition-all text-sm">Jetzt ansehen <span class="material-symbols-outlined text-[18px]">arrow_forward</span></div>
              </div>
            </a>
          </div>
        )}

        <!-- New in your modules -->
        {newSeminars.length > 0 && (
          <div>
            <div class="flex items-center justify-between mb-6">
              <h2 class="text-xl font-bold text-[#05183a] flex items-center gap-2"><span class="material-symbols-outlined text-emerald-500">video_library</span> Weitere Seminare in Ihrem Besitz</h2>
              <a href="/app/lernwelt" class="text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors">Alle ansehen</a>
            </div>
            <!-- Cards Grid -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              {newSeminars.map((seminar: any) => (
                <a href={`/app/player/${seminar.id}`} class="bg-white rounded-3xl border border-gray-200 shadow-sm overflow-hidden flex flex-col hover:-translate-y-1.5 hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] transition-all cursor-pointer group">
                  <div class="h-44 bg-gray-100 relative overflow-hidden">
                     <img src={seminar.image || "https://images.unsplash.com/photo-1541746972996-4e0b0f43e02a?q=80&w=2070&auto=format&fit=crop"} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                     <div class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors"></div>
                  </div>
                  <div class="p-6">
                    <h4 class="font-bold font-headline text-[#05183a] group-hover:text-blue-600 leading-tight mb-2 line-clamp-2 transition-colors">{seminar.title}</h4>
                    <div class="text-xs text-gray-400 font-semibold">{seminar.moduleName} • {seminar.duration || '90 Min.'}</div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </>
    )}

  </div>
</AppLayout>
