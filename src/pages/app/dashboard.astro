---
import AppLayout from '../../layouts/AppLayout.astro';
---

<AppLayout title="Dashboard - AK Kommunal App" currentPath="/app/dashboard">
  <div class="p-8 max-w-6xl mx-auto">
    
    <!-- Greeting -->
    <div class="mb-10">
      <h1 class="text-3xl font-extrabold font-headline text-[#05183a] tracking-tight mb-2">Hallo Herr Müller,</h1>
      <p class="text-gray-500">Willkommen zurück in Ihrer Zentrale.</p>
    </div>

    <!-- Stats Row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm flex items-center gap-5">
        <div class="w-14 h-14 rounded-xl bg-blue-50 text-blue-600 flex items-center justify-center">
          <span class="material-symbols-outlined text-[28px]">token</span>
        </div>
        <div>
          <div class="text-2xl font-bold text-[#05183a]">2 / 3</div>
          <div class="text-xs font-semibold uppercase tracking-widest text-gray-400 mt-1">Aktive Module</div>
        </div>
      </div>
      <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm flex items-center gap-5">
        <div class="w-14 h-14 rounded-xl bg-emerald-50 text-emerald-600 flex items-center justify-center">
          <span class="material-symbols-outlined text-[28px]">task_alt</span>
        </div>
        <div>
          <div class="text-2xl font-bold text-[#05183a]">12</div>
          <div class="text-xs font-semibold uppercase tracking-widest text-gray-400 mt-1">Videos gesehen</div>
        </div>
      </div>
      <div class="bg-white p-6 rounded-2xl border border-gray-200 shadow-sm flex items-center gap-5">
        <div class="w-14 h-14 rounded-xl bg-orange-50 text-orange-600 flex items-center justify-center">
          <span class="material-symbols-outlined text-[28px]">workspace_premium</span>
        </div>
        <div>
          <div class="text-2xl font-bold text-[#05183a]">1</div>
          <div class="text-xs font-semibold uppercase tracking-widest text-gray-400 mt-1">Zertifikate</div>
        </div>
      </div>
    </div>

    <!-- Continue Learning Section -->
    <div class="mb-12">
      <h2 class="text-xl font-bold text-[#05183a] mb-6 flex items-center gap-2"><span class="material-symbols-outlined">play_circle</span> Zuletzt angesehen fortsetzen</h2>
      <a href="/app/player/umsatzsteuer-2026" class="bg-white rounded-3xl border border-gray-200 shadow-sm overflow-hidden flex flex-col md:flex-row group hover:shadow-lg transition-all">
        <div class="w-full md:w-1/3 aspect-video relative">
          <img src="/team/IMG_8181_web.jpg" class="w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 transition-all" />
          <div class="absolute inset-0 bg-black/20 flex items-center justify-center group-hover:bg-black/10 transition-colors">
             <div class="w-16 h-16 rounded-full bg-white/30 backdrop-blur-md flex items-center justify-center text-white border border-white/40">
                <span class="material-symbols-outlined text-[36px] ml-1">play_arrow</span>
             </div>
          </div>
          <div class="absolute bottom-0 left-0 h-1.5 bg-gray-200 w-full">
            <div class="h-full bg-blue-600 w-[65%]"></div>
          </div>
        </div>
        <div class="p-8 flex-1 flex flex-col justify-center">
          <span class="text-[10px] uppercase font-bold text-blue-600 tracking-widest mb-2 bg-blue-50 px-3 py-1 rounded border border-blue-100 w-fit">Modul: Spezialthemen</span>
          <h3 class="text-2xl font-bold text-[#05183a] mb-2 leading-tight">Umsatzsteuer Update 2026 (§ 2b UStG)</h3>
          <p class="text-sm text-gray-500 mb-6">Sie haben 28 Min von 45 Min gesehen. Weiter bei Kaptitel "Beistandsleistungen".</p>
          <div class="font-bold text-[#05183a] flex items-center gap-2 group-hover:gap-3 transition-all text-sm">Jetzt weiterlernen <span class="material-symbols-outlined text-[18px]">arrow_right_alt</span></div>
        </div>
      </a>
    </div>

    <!-- New in your modules -->
    <div>
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-[#05183a] flex items-center gap-2"><span class="material-symbols-outlined text-emerald-500">new_releases</span> Neu in deinen Modulen</h2>
        <a href="/app/lernwelt" class="text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors">Alle ansehen</a>
      </div>
      <!-- Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden flex flex-col hover:-translate-y-1 hover:shadow-md transition-all cursor-pointer">
          <div class="h-40 bg-gray-100 relative">
             <img src="/team/Bild1.jpg" class="w-full h-full object-cover" />
             <div class="absolute top-3 left-3 bg-red-500 text-white text-[9px] font-bold uppercase tracking-widest px-2 py-1 rounded shadow-sm">Neu</div>
          </div>
          <div class="p-6">
            <h4 class="font-bold text-[#05183a] leading-tight mb-2 line-clamp-2">Aktuelle Rechtsprechung BFH: Relevante Urteile</h4>
            <div class="text-xs text-gray-400 font-medium">Praktiker Modul • 45 Min</div>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden flex flex-col hover:-translate-y-1 hover:shadow-md transition-all cursor-pointer">
          <div class="h-40 bg-gray-100 relative">
             <img src="/team/IMG_8168_web.jpg" class="w-full h-full object-cover" />
             <div class="absolute top-3 left-3 bg-red-500 text-white text-[9px] font-bold uppercase tracking-widest px-2 py-1 rounded shadow-sm">Neu</div>
          </div>
          <div class="p-6">
            <h4 class="font-bold text-[#05183a] leading-tight mb-2 line-clamp-2">Jahresabschluss 2025: Checkliste</h4>
            <div class="text-xs text-gray-400 font-medium">Praktiker Modul • 1.5 Std</div>
          </div>
        </div>
      </div>
    </div>

  </div>
</AppLayout>
