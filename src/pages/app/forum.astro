---
import AppLayout from '../../layouts/AppLayout.astro';
---

<AppLayout title="Community Forum - AK Kommunal App" currentPath="/app/forum">
  <div class="h-full bg-[#f8fafc] flex flex-col">
    <!-- Forum Header / Search -->
    <div class="bg-white border-b border-gray-200 px-8 py-8 shrink-0 relative overflow-hidden">
      <!-- Decorative background blur -->
      <div class="absolute top-0 right-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
      
      <div class="max-w-7xl mx-auto relative z-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <div class="flex items-center gap-3 mb-2">
            <span class="material-symbols-outlined text-[24px] text-primary">forum</span>
            <h1 class="text-3xl font-extrabold font-headline text-[#05183a] tracking-tight">Experten-Forum</h1>
          </div>
          <p class="text-[15px] text-gray-500 max-w-xl leading-relaxed">Der geschützte Raum zum fachlichen Austausch. Diskutieren Sie mit Amtskollegen, Kämmerern und unseren Fachreferenten.</p>
        </div>
        
        <div class="flex items-center gap-4 w-full md:w-auto">
          <div class="relative w-full md:w-72">
            <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-[20px]">search</span>
            <input type="text" placeholder="Forum durchsuchen..." class="w-full bg-gray-50 border border-gray-200 text-sm rounded-xl py-2.5 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-[#05183a] font-medium placeholder-gray-400">
          </div>
          <button class="bg-[#05183a] text-white px-5 py-2.5 rounded-xl text-[14px] font-bold shadow-[0_4px_14px_0_rgba(5,24,58,0.2)] hover:bg-blue-900 transition-all hover:-translate-y-0.5 flex items-center gap-2 shrink-0">
            <span class="material-symbols-outlined text-[18px]">add</span> Neues Thema
          </button>
        </div>
      </div>
    </div>

    <!-- Forum Main Content -->
    <div class="flex-1 overflow-y-auto">
      <div class="max-w-7xl mx-auto px-8 py-8 flex flex-col lg:flex-row gap-8">
        
        <!-- Left Sidebar: Categories & Filters -->
        <div class="w-full lg:w-64 shrink-0 flex flex-col gap-8">
          
          <!-- Kategorien -->
          <div>
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3 pl-2">Kategorien</h3>
            <div class="flex flex-col gap-1">
              <a href="#" class="flex items-center justify-between px-3 py-2.5 rounded-xl bg-white shadow-sm border border-gray-100 text-[#05183a] font-bold text-sm">
                <div class="flex items-center gap-3">
                  <span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span>
                  Alle Themen
                </div>
                <span class="bg-gray-100 text-gray-500 text-[10px] px-2 py-0.5 rounded-full">142</span>
              </a>
              <a href="#" class="flex items-center justify-between px-3 py-2.5 rounded-xl hover:bg-gray-100 text-gray-600 font-medium text-sm transition-colors">
                <div class="flex items-center gap-3">
                  <span class="w-2.5 h-2.5 rounded-full border-2 border-orange-400"></span>
                  Finanzwesen
                </div>
                <span class="bg-white border border-gray-200 text-gray-400 text-[10px] px-2 py-0.5 rounded-full">56</span>
              </a>
              <a href="#" class="flex items-center justify-between px-3 py-2.5 rounded-xl hover:bg-gray-100 text-gray-600 font-medium text-sm transition-colors">
                <div class="flex items-center gap-3">
                  <span class="w-2.5 h-2.5 rounded-full border-2 border-emerald-500"></span>
                  Praktiker Modul
                </div>
                <span class="bg-white border border-gray-200 text-gray-400 text-[10px] px-2 py-0.5 rounded-full">34</span>
              </a>
              <a href="#" class="flex items-center justify-between px-3 py-2.5 rounded-xl hover:bg-gray-100 text-gray-600 font-medium text-sm transition-colors">
                <div class="flex items-center gap-3">
                  <span class="w-2.5 h-2.5 rounded-full border-2 border-purple-500"></span>
                  Steuerrecht
                </div>
                <span class="bg-white border border-gray-200 text-gray-400 text-[10px] px-2 py-0.5 rounded-full">28</span>
              </a>
              <a href="#" class="flex items-center justify-between px-3 py-2.5 rounded-xl hover:bg-gray-100 text-gray-600 font-medium text-sm transition-colors">
                <div class="flex items-center gap-3">
                  <span class="w-2.5 h-2.5 rounded-full border-2 border-gray-400"></span>
                  Off-Topic
                </div>
                <span class="bg-white border border-gray-200 text-gray-400 text-[10px] px-2 py-0.5 rounded-full">24</span>
              </a>
            </div>
          </div>

          <!-- Top Contributors -->
          <div>
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3 pl-2">Top Experten</h3>
            <div class="bg-white rounded-2xl border border-gray-200 p-4 shadow-sm flex flex-col gap-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-blue-100 border-2 border-white shadow-sm flex items-center justify-center overflow-hidden shrink-0">
                  <img src="/team/ma4-800x533.jpg" alt="Experte" class="w-full h-full object-cover">
                </div>
                <div>
                  <h4 class="text-sm font-bold text-[#05183a]">Rainer Bäuerle</h4>
                  <p class="text-[11px] text-gray-500 font-medium">Referent · 482 Antworten</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-orange-100 border-2 border-white shadow-sm flex items-center justify-center overflow-hidden shrink-0">
                  <img src="/team/IMG_3724-Bearbeitet-600x400.jpg" alt="Experte" class="w-full h-full object-cover">
                </div>
                <div>
                  <h4 class="text-sm font-bold text-[#05183a]">Freya Marx</h4>
                  <p class="text-[11px] text-gray-500 font-medium">Orga-Team · 315 Antworten</p>
                </div>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-gray-100 border-2 border-white shadow-sm flex items-center justify-center font-bold text-[#05183a] text-xs shrink-0">
                  MS
                </div>
                <div>
                  <h4 class="text-sm font-bold text-[#05183a]">Michael Schwarz</h4>
                  <p class="text-[11px] text-gray-500 font-medium">Kämmerer · 156 Antworten</p>
                </div>
              </div>
            </div>
          </div>

        </div>

        <!-- Right Feed -->
        <div class="flex-1 flex flex-col gap-4">
          <!-- Feed Filters -->
          <div class="flex items-center gap-6 border-b border-gray-200 pb-2">
            <button class="text-sm font-bold text-[#05183a] border-b-2 border-[#05183a] pb-2 -mb-[9px]">Neueste</button>
            <button class="text-sm font-semibold text-gray-400 hover:text-[#05183a] pb-2 -mb-[9px] transition-colors">Beliebt</button>
            <button class="text-sm font-semibold text-gray-400 hover:text-[#05183a] pb-2 -mb-[9px] transition-colors">Ungelesen</button>
            <button class="text-sm font-semibold text-gray-400 hover:text-[#05183a] pb-2 -mb-[9px] transition-colors">Eigene Beiträge</button>
          </div>

          <!-- Pinned Topic -->
          <a href="#" class="bg-blue-50/50 border border-blue-100 rounded-2xl p-5 hover:bg-blue-100/50 transition-colors flex gap-5 group relative overflow-hidden">
            <!-- Pin Icon Badge -->
            <div class="absolute top-0 right-0 w-16 h-16 pointer-events-none overflow-hidden rounded-tr-2xl">
              <div class="absolute top-2 right-2 flex items-center justify-center w-6 h-6 rounded-full bg-blue-100 text-blue-600">
                <span class="material-symbols-outlined text-[14px]">push_pin</span>
              </div>
            </div>

            <div class="w-12 h-12 rounded-full border-2 border-white shadow-sm overflow-hidden shrink-0 mt-1">
              <img src="/team/ma13-800x533.jpg" alt="Author" class="w-full h-full object-cover">
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="bg-blue-600 text-white text-[10px] font-bold px-2 py-0.5 rounded-md uppercase tracking-wide">Angepinnt</span>
                <span class="bg-gray-200/50 text-gray-600 text-[10px] font-bold px-2 py-0.5 rounded-md">News</span>
              </div>
              <h3 class="text-lg font-bold text-[#05183a] group-hover:text-blue-600 transition-colors mb-2 leading-tight">Großes Update im Praktiker Modul: Neue BMF-Schreiben eingearbeitet</h3>
              <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed mb-4">
                Wir haben soeben die neuesten Änderungen bezüglich der Vorsteueraufteilung aus dem BMF-Schreiben von letzter Woche in alle relevanten Video-Lektionen und Skripte übernommen. Hier ist eine kurze Zusammenfassung der wichtigsten Punkte...
              </p>
              <div class="flex items-center justify-between text-[13px]">
                <div class="flex items-center gap-2 text-gray-500 font-medium">
                  <span class="font-bold text-[#05183a]">Alexander Rummer</span>
                  <span>·</span>
                  <span>Heute, 09:00</span>
                </div>
                <div class="flex items-center gap-4 text-gray-500 font-medium">
                  <div class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[16px]">visibility</span> 1.2k</div>
                  <div class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[16px]">chat_bubble</span> 45</div>
                </div>
              </div>
            </div>
          </a>

          <!-- Standard Topic 1 -->
          <a href="#" class="bg-white border border-gray-200 rounded-2xl p-5 hover:border-blue-300 hover:shadow-md transition-all flex gap-5 group">
            <div class="w-12 h-12 rounded-full border-2 border-gray-50 bg-orange-100 text-orange-600 flex items-center justify-center font-bold text-lg shrink-0 mt-1">
               TW
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="bg-orange-50 text-orange-600 border border-orange-100 text-[10px] font-bold px-2 py-0.5 rounded-md">Finanzwesen</span>
              </div>
              <h3 class="text-lg font-bold text-[#05183a] group-hover:text-blue-600 transition-colors mb-2 leading-tight">Erfahrungen mit TCMS Software-Anbietern für Kommunen?</h3>
              <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed mb-4">
                Hallo zusammen, wir prüfen aktuell die Einführung eines Tax Compliance Management Systems. Hat jemand bereits Erfahrungen mit speziellen Anbietern, die den kommunalen Kontext gut abdecken?
              </p>
              <div class="flex items-center justify-between text-[13px]">
                <div class="flex items-center gap-2 text-gray-500 font-medium">
                  <span class="font-bold text-[#05183a]">Thomas Wagner</span>
                  <span>·</span>
                  <span>Gestern, 14:30</span>
                </div>
                <div class="flex items-center gap-4 text-gray-500 font-medium">
                  <div class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[16px]">visibility</span> 234</div>
                  <div class="flex items-center gap-1.5 text-blue-600"><span class="material-symbols-outlined text-[16px]">chat_bubble</span> 12</div>
                </div>
              </div>
            </div>
            <!-- Avatars of repliers -->
            <div class="hidden md:flex items-end mb-1">
              <div class="flex -space-x-3">
                <img class="w-8 h-8 rounded-full border-2 border-white" src="/team/ma4-800x533.jpg" alt="">
                <img class="w-8 h-8 rounded-full border-2 border-white" src="/team/ma5-800x533.jpg" alt="">
                <div class="flex items-center justify-center w-8 h-8 rounded-full border-2 border-white bg-gray-100 text-[10px] font-bold text-gray-500">+3</div>
              </div>
            </div>
          </a>

          <!-- Standard Topic 2 -->
          <a href="#" class="bg-white border border-gray-200 rounded-2xl p-5 hover:border-blue-300 hover:shadow-md transition-all flex gap-5 group">
            <div class="w-12 h-12 rounded-full border-2 border-gray-50 bg-emerald-100 text-emerald-600 flex items-center justify-center font-bold text-lg shrink-0 mt-1">
               LB
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-1.5">
                <span class="bg-emerald-50 text-emerald-600 border border-emerald-100 text-[10px] font-bold px-2 py-0.5 rounded-md">Steuerrecht</span>
                <span class="bg-gray-100 text-gray-500 text-[10px] font-bold px-2 py-0.5 rounded-md">§ 2b UStG</span>
              </div>
              <h3 class="text-lg font-bold text-[#05183a] group-hover:text-blue-600 transition-colors mb-2 leading-tight">Berechnung der Bagatellgrenze bei interkommunaler Zusammenarbeit</h3>
              <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed mb-4">
                Wie exakt berechnet ihr die 35.000€ Grenze bei der interkommunalen Zusammenarbeit nach § 2b UStG wenn Personalkosten erst nachlaufend spitz abgerechnet werden?
              </p>
              <div class="flex items-center justify-between text-[13px]">
                <div class="flex items-center gap-2 text-gray-500 font-medium">
                  <span class="font-bold text-[#05183a]">Laura Bauer</span>
                  <span>·</span>
                  <span>22. März 2026</span>
                </div>
                <div class="flex items-center gap-4 text-gray-500 font-medium">
                  <div class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[16px]">visibility</span> 891</div>
                  <div class="flex items-center gap-1.5 text-gray-400"><span class="material-symbols-outlined text-[16px]">chat_bubble</span> 0</div>
                </div>
              </div>
            </div>
          </a>

          <!-- Pagination -->
          <div class="flex items-center justify-center gap-2 mt-6">
            <button class="w-10 h-10 rounded-xl bg-white border border-gray-200 flex items-center justify-center text-gray-400 hover:text-[#05183a] hover:bg-gray-50 transition-colors shadow-sm disabled:opacity-50" disabled>
              <span class="material-symbols-outlined text-[20px]">chevron_left</span>
            </button>
            <button class="w-10 h-10 rounded-xl bg-[#05183a] text-white font-bold shadow-sm">1</button>
            <button class="w-10 h-10 rounded-xl bg-white border border-gray-200 font-bold text-gray-600 hover:bg-gray-50 transition-colors shadow-sm">2</button>
            <button class="w-10 h-10 rounded-xl bg-white border border-gray-200 font-bold text-gray-600 hover:bg-gray-50 transition-colors shadow-sm">3</button>
            <span class="text-gray-400 font-bold px-2">...</span>
            <button class="w-10 h-10 rounded-xl bg-white border border-gray-200 font-bold text-gray-600 hover:bg-gray-50 transition-colors shadow-sm">12</button>
            <button class="w-10 h-10 rounded-xl bg-white border border-gray-200 flex items-center justify-center text-[#05183a] hover:bg-gray-50 transition-colors shadow-sm">
              <span class="material-symbols-outlined text-[20px]">chevron_right</span>
            </button>
          </div>

        </div>
      </div>
      
      <!-- Footer spacing -->
      <div class="h-12"></div>
    </div>
  </div>
</AppLayout>
