<AppLayout title="Community Forum - AK Kommunal App" currentPath="/app/forum">
  <div class="h-full bg-[#f8fafc] flex flex-col">
    <!-- Forum Header / Search -->
    <div class="bg-white border-b border-gray-200 px-8 py-8 shrink-0 relative overflow-hidden">
      <!-- Decorative background blur -->
      <div class="absolute top-0 right-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>
      
      <div class="max-w-7xl mx-auto relative z-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
          <div class="flex items-center gap-3 mb-2">
            <span class="material-symbols-outlined text-[24px] text-primary">forum</span>
            <h1 class="text-3xl font-extrabold font-headline text-[#05183a] tracking-tight">Experten-Forum</h1>
          </div>
          <p class="text-[15px] text-gray-500 max-w-xl leading-relaxed">Der geschützte Raum zum fachlichen Austausch. Diskutieren Sie mit Amtskollegen, Kämmerern und unseren Fachreferenten.</p>
        </div>
        
        <div class="flex items-center gap-4 w-full md:w-auto">
          <div class="relative w-full md:w-72">
            <span class="material-symbols-outlined absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-[20px]">search</span>
            <input type="text" placeholder="Forum durchsuchen..." class="w-full bg-gray-50 border border-gray-200 text-sm rounded-xl py-2.5 pl-10 pr-4 focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all text-[#05183a] font-medium placeholder-gray-400">
          </div>
          <button onclick="document.getElementById('new-topic-modal').classList.remove('hidden')" class="bg-[#05183a] text-white px-5 py-2.5 rounded-xl text-[14px] font-bold shadow-md hover:bg-blue-900 transition-all hover:-translate-y-0.5 flex items-center gap-2 shrink-0">
            <span class="material-symbols-outlined text-[18px]">add</span> Neues Thema
          </button>
        </div>
      </div>
    </div>

    <!-- Forum Main Content -->
    <div class="flex-1 overflow-y-auto">
      <div class="max-w-7xl mx-auto px-8 py-8 flex flex-col lg:flex-row gap-8">
        
        <!-- Left Sidebar: Categories & Filters -->
        <div class="w-full lg:w-64 shrink-0 flex flex-col gap-8">
          
          <!-- Kategorien -->
          <div>
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3 pl-2">Kategorien</h3>
            <div class="flex flex-col gap-1">
              <a href={`?sort=${currentSort}`} class={`flex items-center justify-between px-3 py-2.5 rounded-xl transition-colors text-sm ${!currentCategory ? 'font-bold bg-white shadow-sm border border-gray-100 text-[#05183a]' : 'font-medium text-gray-600 hover:bg-gray-100'}`}>
                <div class="flex items-center gap-3">
                  <span class={`w-2.5 h-2.5 rounded-full ${!currentCategory ? 'bg-blue-500' : 'bg-gray-300'}`}></span>
                  Alle Themen
                </div>
                <span class={`${!currentCategory ? 'bg-gray-100 text-gray-500' : 'bg-white border border-gray-200 text-gray-400'} text-[10px] px-2 py-0.5 rounded-full`}>{categoryCounts.total}</span>
              </a>
              <a href={`?category=Finanzwesen&sort=${currentSort}`} class={`flex items-center justify-between px-3 py-2.5 rounded-xl transition-colors text-sm ${currentCategory === 'Finanzwesen' ? 'font-bold bg-white shadow-sm border border-gray-100 text-[#05183a]' : 'font-medium text-gray-600 hover:bg-gray-100'}`}>
                <div class="flex items-center gap-3">
                  <span class={`w-2.5 h-2.5 rounded-full border-2 ${currentCategory === 'Finanzwesen' ? 'border-orange-400 bg-orange-400' : 'border-orange-400'}`}></span>
                  Finanzwesen
                </div>
                <span class={`${currentCategory === 'Finanzwesen' ? 'bg-gray-100 text-gray-500' : 'bg-white border border-gray-200 text-gray-400'} text-[10px] px-2 py-0.5 rounded-full`}>{categoryCounts.finanzwesen}</span>
              </a>
              <a href={`?category=Praktiker Modul&sort=${currentSort}`} class={`flex items-center justify-between px-3 py-2.5 rounded-xl transition-colors text-sm ${currentCategory === 'Praktiker Modul' ? 'font-bold bg-white shadow-sm border border-gray-100 text-[#05183a]' : 'font-medium text-gray-600 hover:bg-gray-100'}`}>
                <div class="flex items-center gap-3">
                  <span class={`w-2.5 h-2.5 rounded-full border-2 ${currentCategory === 'Praktiker Modul' ? 'border-emerald-500 bg-emerald-500' : 'border-emerald-500'}`}></span>
                  Praktiker Modul
                </div>
                <span class={`${currentCategory === 'Praktiker Modul' ? 'bg-gray-100 text-gray-500' : 'bg-white border border-gray-200 text-gray-400'} text-[10px] px-2 py-0.5 rounded-full`}>{categoryCounts.praktiker}</span>
              </a>
              <a href={`?category=Steuerrecht&sort=${currentSort}`} class={`flex items-center justify-between px-3 py-2.5 rounded-xl transition-colors text-sm ${currentCategory === 'Steuerrecht' ? 'font-bold bg-white shadow-sm border border-gray-100 text-[#05183a]' : 'font-medium text-gray-600 hover:bg-gray-100'}`}>
                <div class="flex items-center gap-3">
                  <span class={`w-2.5 h-2.5 rounded-full border-2 ${currentCategory === 'Steuerrecht' ? 'border-purple-500 bg-purple-500' : 'border-purple-500'}`}></span>
                  Steuerrecht
                </div>
                <span class={`${currentCategory === 'Steuerrecht' ? 'bg-gray-100 text-gray-500' : 'bg-white border border-gray-200 text-gray-400'} text-[10px] px-2 py-0.5 rounded-full`}>{categoryCounts.steuerrecht}</span>
              </a>
              <a href={`?category=Off-Topic&sort=${currentSort}`} class={`flex items-center justify-between px-3 py-2.5 rounded-xl transition-colors text-sm ${currentCategory === 'Off-Topic' ? 'font-bold bg-white shadow-sm border border-gray-100 text-[#05183a]' : 'font-medium text-gray-600 hover:bg-gray-100'}`}>
                <div class="flex items-center gap-3">
                  <span class={`w-2.5 h-2.5 rounded-full border-2 ${currentCategory === 'Off-Topic' ? 'border-gray-400 bg-gray-400' : 'border-gray-400'}`}></span>
                  Off-Topic
                </div>
                <span class={`${currentCategory === 'Off-Topic' ? 'bg-gray-100 text-gray-500' : 'bg-white border border-gray-200 text-gray-400'} text-[10px] px-2 py-0.5 rounded-full`}>{categoryCounts.offtopic}</span>
              </a>
            </div>
          </div>

          <!-- Top Contributors Removed as requested -->


        </div>

        <!-- Right Feed -->
        <div class="flex-1 flex flex-col gap-4">
          <!-- Feed Filters -->
          <div class="flex items-center gap-6 border-b border-gray-200 pb-2">
            <a href={`?sort=newest${currentCategory ? `&category=${currentCategory}` : ''}`} class={`text-sm tracking-wide transition-colors ${currentSort === 'newest' ? 'font-bold text-[#05183a] border-b-2 border-[#05183a] pb-2 -mb-[9px]' : 'font-semibold text-gray-400 hover:text-[#05183a] pb-2 -mb-[9px]'}`}>Neueste</a>
            <a href={`?sort=popular${currentCategory ? `&category=${currentCategory}` : ''}`} class={`text-sm tracking-wide transition-colors ${currentSort === 'popular' ? 'font-bold text-[#05183a] border-b-2 border-[#05183a] pb-2 -mb-[9px]' : 'font-semibold text-gray-400 hover:text-[#05183a] pb-2 -mb-[9px]'}`}>Beliebt</a>
            <a href={`?sort=unanswered${currentCategory ? `&category=${currentCategory}` : ''}`} class={`text-sm tracking-wide transition-colors ${currentSort === 'unanswered' ? 'font-bold text-[#05183a] border-b-2 border-[#05183a] pb-2 -mb-[9px]' : 'font-semibold text-gray-400 hover:text-[#05183a] pb-2 -mb-[9px]'}`}>Unbeantwortet</a>
            <a href={`?sort=mine${currentCategory ? `&category=${currentCategory}` : ''}`} class={`text-sm tracking-wide transition-colors ${currentSort === 'mine' ? 'font-bold text-[#05183a] border-b-2 border-[#05183a] pb-2 -mb-[9px]' : 'font-semibold text-gray-400 hover:text-[#05183a] pb-2 -mb-[9px]'}`}>Eigene Beiträge</a>
          </div>

          <!-- Das Forum / oder Paywall -->
          {!hasAccess ? (
            <div class="bg-white border text-center border-gray-200 rounded-2xl p-16 flex flex-col items-center justify-center gap-6 shadow-sm overflow-hidden relative">
              <!-- Decorative background -->
              <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3 pointer-events-none"></div>

              <div class="w-20 h-20 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center shadow-inner relative z-10">
                <span class="material-symbols-outlined text-[40px]">lock</span>
              </div>
              
              <div class="max-w-md mx-auto relative z-10 mt-2">
                <h2 class="text-2xl font-extrabold text-[#05183a] mb-4 font-headline">Exklusiver Austausch<br/>für Mitglieder</h2>
                <p class="text-gray-500 text-[15px] leading-relaxed mb-8 font-medium">
                  Unser Behörden-Forum und der direkte Fachaustausch mit den Referenten steht aus Qualitätsgründen exklusiv den Mitgliedern von <strong class="text-[#05183a]">AK Kommunal</strong> zur Verfügung.
                </p>

                <a href="/mitglied-werden" class="inline-flex items-center gap-2 px-8 py-3.5 bg-gradient-to-r from-[#05183a] to-blue-900 border border-transparent rounded-xl shadow-lg shadow-[#05183a]/20 text-white font-bold hover:shadow-xl hover:-translate-y-0.5 transition-all w-full justify-center">
                  <span class="material-symbols-outlined text-[20px]">workspace_premium</span>
                  Jetzt Mitglied werden
                </a>
              </div>
            </div>
          ) : (
            <Fragment>
              <!-- Dynamic Pinned Topic (Big Header) -->
              {topPinnedTopic && (
                <a href={`/app/forum/${topPinnedTopic.id}`} class="bg-blue-50/50 border border-blue-100 rounded-2xl p-5 hover:bg-blue-100/50 transition-colors flex gap-5 group relative overflow-hidden">
                  <div class="absolute top-0 right-0 w-16 h-16 pointer-events-none overflow-hidden rounded-tr-2xl">
                    <div class="absolute top-2 right-2 flex items-center justify-center w-6 h-6 rounded-full bg-blue-100 text-blue-600">
                      <span class="material-symbols-outlined text-[14px]">push_pin</span>
                    </div>
                  </div>

                  <div class="w-12 h-12 rounded-full border-2 border-white shadow-sm overflow-hidden shrink-0 mt-1 bg-[#05183a] text-white flex items-center justify-center font-bold text-lg">
                     {topPinnedTopic.author_avatar_url ? (
                       <img src={topPinnedTopic.author_avatar_url} class="w-full h-full object-cover" />
                     ) : (
                       topPinnedTopic.author_name.charAt(0).toUpperCase()
                     )}
                  </div>
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1.5">
                      <span class="bg-blue-600 text-white text-[10px] font-bold px-2 py-0.5 rounded-md uppercase tracking-wide">Angepinnt</span>
                      <span class="bg-blue-100 text-blue-700 text-[10px] font-bold px-2 py-0.5 rounded-md">{topPinnedTopic.category}</span>
                    </div>
                    <h3 class="text-lg font-bold text-[#05183a] group-hover:text-blue-600 transition-colors mb-2 leading-tight">{topPinnedTopic.title}</h3>
                    <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed mb-4">
                      {topPinnedTopic.content}
                    </p>
                    <div class="flex items-center justify-between text-[13px]">
                      <div class="flex items-center gap-2 text-gray-500 font-medium">
                        <span class="font-bold text-[#05183a]">{topPinnedTopic.author_name}</span>
                        <span>·</span>
                        <span>vor {timeAgo(topPinnedTopic.created_at)}</span>
                      </div>
                      <div class="flex items-center gap-4 text-gray-500 font-medium">
                        <div class="flex items-center gap-1.5 text-blue-500"><span class="material-symbols-outlined text-[16px]">thumb_up</span> {topPinnedTopic.likes || 0}</div>
                        <div class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[16px]">visibility</span> {topPinnedTopic.views || 0}</div>
                        <div class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[16px]">chat_bubble</span> {topPinnedTopic.replies || 0}</div>
                      </div>
                    </div>
                  </div>
                </a>
              )}

              {notification && (
                <div class={`p-4 rounded-xl text-sm font-bold border ${notification.startsWith('Fehler') ? 'bg-red-50 text-red-600 border-red-200' : 'bg-emerald-50 text-emerald-700 border-emerald-200'}`}>
                  {notification}
                </div>
              )}

              <!-- Dynamic Forum Topics -->
              {forumTopics.length === 0 ? (
                <div class="bg-white border border-gray-200 rounded-2xl p-10 text-center flex flex-col items-center gap-3">
                  <span class="material-symbols-outlined text-gray-300 text-[48px]">forum</span>
                  <h3 class="text-lg font-bold text-[#05183a]">Noch keine Themen</h3>
                  <p class="text-sm text-gray-500">Seien Sie der Erste, der eine Diskussion startet!</p>
                </div>
              ) : regularTopics.map((topic: any) => (
                <a href={`/app/forum/${topic.id}`} class="bg-white border border-gray-200 rounded-2xl p-5 hover:border-blue-300 hover:shadow-md transition-all flex gap-5 group relative">
                  {topic.is_pinned && (
                    <div class="absolute top-4 right-4 text-amber-500" title="Angepinnt">
                      <span class="material-symbols-outlined text-[18px]">push_pin</span>
                    </div>
                  )}
                  <div class="w-12 h-12 rounded-full border-2 border-gray-50 bg-[#05183a] text-white flex items-center justify-center font-bold text-lg shrink-0 mt-1 overflow-hidden">
                     {topic.author_avatar_url ? (
                       <img src={topic.author_avatar_url} class="w-full h-full object-cover" />
                     ) : (
                       topic.author_name.charAt(0).toUpperCase()
                     )}
                  </div>
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1.5">
                      <span class="bg-blue-50 text-blue-600 border border-blue-100 text-[10px] font-bold px-2 py-0.5 rounded-md">
                        {topic.category}
                      </span>
                    </div>
                    <h3 class="text-lg font-bold text-[#05183a] group-hover:text-blue-600 transition-colors mb-2 leading-tight">{topic.title}</h3>
                    <p class="text-sm text-gray-500 line-clamp-2 leading-relaxed mb-4">
                      {topic.content}
                    </p>
                    <div class="flex items-center justify-between text-[13px]">
                      <div class="flex items-center gap-2 text-gray-500 font-medium">
                        <span class="font-bold text-[#05183a]">{topic.author_name}</span>
                        <span>·</span>
                        <span>vor {timeAgo(topic.created_at)}</span>
                      </div>
                      <div class="flex items-center gap-4 text-gray-500 font-medium">
                        <div class="flex items-center gap-1.5 text-blue-500"><span class="material-symbols-outlined text-[16px]">thumb_up</span> {topic.likes || 0}</div>
                        <div class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[16px]">visibility</span> {topic.views || 0}</div>
                        <div class="flex items-center gap-1.5"><span class="material-symbols-outlined text-[16px]">chat_bubble</span> {topic.replies || 0}</div>
                      </div>
                    </div>
                  </div>
                </a>
              ))}

              <!-- Pagination -->
              {totalPages > 1 && (
                <div class="flex items-center justify-center gap-2 mt-6">
                  <a href={currentPage > 1 ? `?page=${currentPage - 1}` : '#'} 
                     class={`w-10 h-10 rounded-xl bg-white border border-gray-200 flex items-center justify-center transition-colors shadow-sm ${currentPage <= 1 ? 'text-gray-300 pointer-events-none' : 'text-gray-600 hover:text-[#05183a] hover:bg-gray-50'}`}>
                    <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                  </a>
                  
                  {paginationPages.map((pageNum) => (
                    pageNum === '...' ? (
                      <span class="text-gray-400 font-bold px-1">...</span>
                    ) : (
                      <a href={`?page=${pageNum}`} class={`w-10 h-10 rounded-xl border flex items-center justify-center font-bold text-sm transition-colors shadow-sm ${pageNum === currentPage ? 'bg-[#05183a] text-white border-transparent' : 'bg-white border-gray-200 text-gray-600 hover:bg-gray-50'}`}>
                        {pageNum}
                      </a>
                    )
                  ))}

                  <a href={currentPage < totalPages ? `?page=${currentPage + 1}` : '#'} 
                     class={`w-10 h-10 rounded-xl bg-white border border-gray-200 flex items-center justify-center transition-colors shadow-sm ${currentPage >= totalPages ? 'text-gray-300 pointer-events-none' : 'text-gray-600 hover:text-[#05183a] hover:bg-gray-50'}`}>
                    <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                  </a>
                </div>
              )}
            </Fragment>
          )}

        </div>
      </div>
      
      <div class="h-12"></div>
    </div>
  </div>

  <!-- Modal for Creating New Topic -->
  <div id="new-topic-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4 opacity-0 transition-opacity aria-[hidden=false]:opacity-100" style="transition: opacity 0.2s">
    <div class="bg-white rounded-3xl w-full max-w-2xl shadow-2xl overflow-hidden flex flex-col max-h-[90vh]">
      <div class="px-8 py-6 border-b border-gray-100 flex items-center justify-between shrink-0">
        <h2 class="text-xl font-bold text-[#05183a] font-headline">Neues Thema erstellen</h2>
        <button onclick="document.getElementById('new-topic-modal').classList.add('hidden')" class="text-gray-400 hover:text-[#05183a] transition-colors">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>
      <form method="POST" class="p-8 flex flex-col gap-6 overflow-y-auto" onsubmit="this.querySelector('button[type=submit]').disabled=true; this.querySelector('button[type=submit]').innerText='Wird veröffentlicht...';">
        <div class="space-y-2">
          <label class="text-xs font-bold text-gray-600 uppercase tracking-widest">Kategorie</label>
          <select name="category" required class="w-full bg-gray-50 border border-gray-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 px-4 py-3 rounded-xl outline-none text-sm font-medium text-[#05183a] appearance-none">
            <option value="Finanzwesen">Finanzwesen</option>
            <option value="Praktiker Modul">Praktiker Modul</option>
            <option value="Steuerrecht">Steuerrecht</option>
            <option value="Off-Topic">Off-Topic</option>
          </select>
        </div>
        <div class="space-y-2">
          <label class="text-xs font-bold text-gray-600 uppercase tracking-widest">Titel des Themas</label>
          <input type="text" name="title" required placeholder="Fassen Sie Ihr Thema kurz zusammen..." class="w-full bg-gray-50 border border-gray-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 px-4 py-3 rounded-xl outline-none text-sm font-bold text-[#05183a]" />
        </div>
        <div class="space-y-2">
          <label class="text-xs font-bold text-gray-600 uppercase tracking-widest">Ihr Beitrag</label>
          <textarea name="content" required rows="6" placeholder="Beschreiben Sie Ihr Anliegen, Ihre Frage oder Ihr Problem..." class="w-full bg-gray-50 border border-gray-200 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 px-4 py-3 rounded-xl outline-none text-sm font-medium text-[#05183a] resize-none"></textarea>
        </div>
        
        <div class="pt-4 flex justify-end gap-3 shrink-0">
           <button type="button" onclick="document.getElementById('new-topic-modal').classList.add('hidden')" class="px-6 py-2.5 rounded-xl text-sm font-bold text-gray-500 hover:bg-gray-100 transition-colors">
             Abbrechen
           </button>
           <button type="submit" class="bg-[#05183a] text-white px-6 py-2.5 rounded-xl text-sm font-bold shadow-md hover:bg-blue-900 transition-all hover:-translate-y-0.5">
             Eintrag veröffentlichen
           </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // Just a quick helper to open the modal nicely
    const modal = document.getElementById('new-topic-modal');
    if (modal) {
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
            const isHidden = modal.classList.contains('hidden');
            if (!isHidden) {
              // trigger reflow
              void modal.offsetWidth;
              modal.setAttribute('aria-hidden', 'false');
            } else {
              modal.setAttribute('aria-hidden', 'true');
            }
          }
        });
      });
      observer.observe(modal, { attributes: true });
    }
  </script>
</AppLayout>
