---
import AppLayout from '../../layouts/AppLayout.astro';
import { getSupabaseServer } from '../../lib/supabase';

const supabase = getSupabaseServer(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect('/login');
}

const firstName = user.user_metadata?.first_name || '';
const lastName = user.user_metadata?.last_name || '';
const displayName = firstName ? `${firstName} ${lastName}` : (user.email || 'Gast');
const avatarUrl = user.user_metadata?.avatar_url || null;

let notification = '';

// Form POST (neues Thema)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const title = formData.get('title')?.toString();
    const category = formData.get('category')?.toString();
    const content = formData.get('content')?.toString();

    if (title && category && content) {
      const { error: insertError } = await supabase.from('forum_topics').insert({
        title,
        category,
        content,
        author_id: user.id,
        author_name: displayName,
        author_avatar_url: avatarUrl
      });
      if (insertError) {
        notification = `Fehler beim Erstellen: ${insertError.message}`;
      } else {
        // Erfolgreich! Wir leiten um, damit F5 (Neuladen) das Formular nicht nochmal sendet
        return Astro.redirect('/app/forum');
      }
    }
  } catch (err: any) {
    notification = `Systemfehler: ${err.message}`;
  }
}

// Profil abrufen für Berechtigungs-Check
const { data: profile, error: profileError } = await supabase
  .from('user_profiles')
  .select('role, has_membership')
  .eq('id', user.id)
  .maybeSingle();

if (profileError) {
  console.error("Supabase Profile Fetch Error:", profileError);
}

const isAdmin = profile?.role === 'admin';
const hasAccess = isAdmin || profile?.has_membership;

let forumTopics: any[] = [];
let topPinnedTopic: any = null;
let regularTopics: any[] = [];

// Dynamische Paginierung & Filterung
const currentPage = parseInt(Astro.url.searchParams.get('page') || '1');
const currentCategory = Astro.url.searchParams.get('category');
const currentSort = Astro.url.searchParams.get('sort') || 'newest';
const ITEMS_PER_PAGE = 10;
const offset = (currentPage - 1) * ITEMS_PER_PAGE;

let totalCount = 0;
let totalPages = 1;

let categoryCounts = { total: 0, finanzwesen: 0, praktiker: 0, steuerrecht: 0, offtopic: 0 };

if (hasAccess) {
  // --- 1. Zähler für die Sidebar (Parallel) ---
  const fetchCount = async (cat: string | null) => {
    let q = supabase.from('forum_topics').select('id', { count: 'exact', head: true });
    if (cat) q = q.eq('category', cat);
    const { count } = await q;
    return count || 0;
  };
  
  const [total, finanzwesen, praktiker, steuerrecht, offtopic] = await Promise.all([
    fetchCount(null),
    fetchCount('Finanzwesen'),
    fetchCount('Praktiker Modul'),
    fetchCount('Steuerrecht'),
    fetchCount('Off-Topic')
  ]);
  
  categoryCounts = { total, finanzwesen, praktiker, steuerrecht, offtopic };

  // --- 2. Dynamische Feed-Abfrage aufbauen ---
  let query = supabase
    .from('forum_topics')
    .select('*', { count: 'exact' });

  // Kategorie Filter
  if (currentCategory) {
    query = query.eq('category', currentCategory);
  }

  // Sortierungs-Bedingungen (Unbeantwortet / Eigene)
  if (currentSort === 'mine') {
    query = query.eq('author_id', user.id);
  } else if (currentSort === 'unanswered') {
    query = query.eq('replies', 0);
  }

  // Die Sortierung selbst
  if (currentSort === 'popular') {
    query = query.order('views', { ascending: false });
  } else {
    // Standard (Neueste) - Nur hier wollen wir den Pin ganz oben
    if (!currentCategory && currentSort === 'newest') {
      query = query.order('is_pinned', { ascending: false });
    }
    query = query.order('created_at', { ascending: false });
  }

  // Paginierung anwenden
  query = query.range(offset, offset + ITEMS_PER_PAGE - 1);

  const { data: rawTopics, count } = await query;

  forumTopics = rawTopics || [];
  totalCount = count || 0;
  totalPages = Math.max(1, Math.ceil(totalCount / ITEMS_PER_PAGE));
  
  // Zeige den großen Header-Post nur auf Seite 1 an, wenn kein Filter/Sort aktiv ist
  if (currentPage === 1 && currentSort === 'newest' && !currentCategory && forumTopics.length > 0 && forumTopics[0].is_pinned) {
    topPinnedTopic = forumTopics[0];
    regularTopics = forumTopics.slice(1);
  } else {
    // Filter aktiv oder nicht Seite 1 -> ganz normale Liste rendern
    regularTopics = forumTopics;
  }
}

function timeAgo(dateString: string) {
  const date = new Date(dateString);
  const seconds = Math.floor((new Date().getTime() - date.getTime()) / 1000);
  let interval = seconds / 86400;
  if (interval > 1) return Math.floor(interval) + " Tagen";
  interval = seconds / 3600;
  if (interval > 1) return Math.floor(interval) + " Stunden";
  interval = seconds / 60;
  if (interval >= 1) return Math.floor(interval) + " Minuten";
  return "gerade eben";
}

let paginationPages: (number | string)[] = [];
if (totalPages > 1) {
  for (let i = 1; i <= totalPages; i++) {
    if (totalPages <= 7 || i === 1 || i === totalPages || (i >= currentPage - 1 && i <= currentPage + 1)) {
      paginationPages.push(i);
    } else if (i === currentPage - 2 || i === currentPage + 2) {
      paginationPages.push('...');
    }
  }
}
