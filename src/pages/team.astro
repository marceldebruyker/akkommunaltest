import TopNavBar from '../components/TopNavBar.astro';
import FooterSection from '../components/FooterSection.astro';

const teamMembers = [
  {
    name: "Marius Henkel",
    role: "Wirtschaftsprüfer, Partner",
    image: "/team/mariushenkel-800x533.jpg"
  },
  {
    name: "Susanne Hauser-Reh",
    role: "Wirtschaftsprüferin, Steuerberaterin, Partnerin",
    image: "/team/Susanne-Reh-4.jpg"
  },
  {
    name: "Alexander Rummer",
    role: "Steuerberater",
    image: "/team/ma13-800x533.jpg"
  },
  {
    name: "Thomas Schweizer",
    role: "Steuerberater",
    image: "/team/ma5-800x533.jpg"
  },
  {
    name: "Sarah Bender",
    role: "Steuerberaterin",
    image: "/team/Bender_Sarah-SABE-800x533.jpg"
  },
  {
    name: "Rainer Bäuerle",
    role: "Dipl.-Betriebswirt",
    image: "/team/ma4-800x533.jpg"
  },
  {
    name: "Wiebke Schwebke",
    role: "Bachelor of Science",
    image: "/team/BWP-Videohintergrund-1_gespiegelt-Wiebke-klein-800x533.png"
  },
  {
    name: "Robert Wachtel",
    role: "Bachelor of Arts",
    image: "/team/Bild1.jpg"
  },
  {
    name: "Fabian Henkel",
    role: "Dipl. Betriebswirt (FH)",
    image: "/team/Fabian-Henkel-800x533.jpg"
  },
  {
    name: "Sarah Schweizer",
    role: "Rechtsanwältin, Partnerin",
    image: "/team/ma10-800x533.jpg"
  },
  {
    name: "Peter Pichl",
    role: "Rechtsanwalt, Counsel",
    image: "/team/PeterPichl_2021050615394-klein-1200x800-1-800x533.jpg"
  },
  {
    name: "Jill-Emmy Vaupel",
    role: "Rechtsanwältin, Counsel",
    image: "/team/ma3-1200x800-1-800x533.jpg"
  },
  {
    name: "Fernando Horn",
    role: "Rechtsanwalt, Counsel",
    image: "/team/Fernando-Horn-bw-schweizer_gr-800x533.jpg"
  }
