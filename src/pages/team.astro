---

<Layout title="Das Team - AK Kommunal">
  <TopNavBar />

  <main class="w-full bg-surface pt-32 pb-24 relative overflow-hidden min-h-screen">
    <!-- Abstract Background styling -->
    <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-primary/5 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>

    <div class="max-w-6xl mx-auto px-6 lg:px-10 relative z-10 mb-12 animate-[fadeInUp_1s_ease-out]">
      <div class="flex items-center gap-4 mb-4">
        <div class="h-[2px] w-12 bg-primary"></div>
        <h2 class="text-[10px] md:text-xs font-bold text-primary tracking-widest uppercase">
          Die Menschen dahinter
        </h2>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold font-headline text-primary tracking-tight leading-[1.1] pb-2 mb-6">
        Das Team von <br/>
        <span class="text-primary-fixed-dim">AK Kommunal</span>
      </h1>
      <p class="text-lg font-body leading-relaxed font-light text-on-surface-variant max-w-2xl">
        Wir bündeln jahrzehntelange Erfahrung aus Wirtschaftsprüfung, Steuerberatung und Prozessmanagement – speziell ausgerichtet auf die Bedürfnisse kommunaler Organisationen.
      </p>
    </div>

    <!-- Ansprechpartner Highlight Section (Like old screenshot, but premium) -->
    <div class="max-w-6xl mx-auto px-8 mb-24 animate-[fadeInUp_1s_ease-out_0.2s_both]">
      <div class="bg-surface-container-lowest rounded-3xl overflow-hidden shadow-[0_20px_40px_-15px_rgba(5,24,58,0.08)] border border-outline-variant/30 flex flex-col md:flex-row items-stretch group">
        <div class="w-full md:w-5/12 aspect-[4/3] md:h-auto md:aspect-auto relative overflow-hidden bg-surface-variant/20">
          <!-- Main contact image -->
          <img src="/team/IMG_3724-Bearbeitet-600x400.jpg" alt="Freya Marx" class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700 ease-out" />
        </div>
        
        <div class="w-full md:w-7/12 p-10 md:p-16 relative">
          <!-- Decorative Logo Watermark inside highlight -->
          <span class="material-symbols-outlined absolute top-10 right-10 text-[120px] text-outline-variant/5 transform -rotate-12 pointer-events-none select-none">
            assured_workload
          </span>

          <h3 class="text-[10px] md:text-xs font-bold text-primary tracking-[0.2em] uppercase mb-4">Ihre Ansprechpartnerin</h3>
          <h2 class="text-3xl md:text-4xl font-extrabold font-headline text-primary mb-2">Freya Marx</h2>
          <p class="text-primary/70 text-base md:text-lg font-medium mb-10">Organisationsleitung AK Kommunal</p>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 text-sm text-on-surface-variant font-body">
            <div>
              <p class="leading-relaxed">
                <strong class="text-primary tracking-wide text-xs uppercase mb-1 block">Standort</strong>
                <span class="font-bold text-on-surface">BW PARTNER</span><br/>
                Standort Stuttgart<br/>
                Hauptstr. 41<br/>
                70563 Stuttgart (Vaihingen)
              </p>
            </div>
            <div class="flex flex-col gap-4 justify-start">
              <strong class="text-primary tracking-wide text-xs uppercase mb-[-10px] block">Direktkontakt</strong>
              <div class="flex items-center gap-3 group/link">
                <span class="w-10 h-10 rounded-full border border-primary/20 flex items-center justify-center text-primary group-hover/link:bg-primary group-hover/link:text-white transition-all duration-300">
                  <span class="material-symbols-outlined text-[18px]">phone</span>
                </span>
                <a href="tel:+49071116401650" class="hover:text-primary transition-colors font-medium">
                  +49 0711 1640 1650
                </a>
              </div>
              <div class="flex items-center gap-3 group/link">
                <span class="w-10 h-10 rounded-full flex-shrink-0 border border-primary/20 flex items-center justify-center text-primary group-hover/link:bg-primary group-hover/link:text-white transition-all duration-300">
                  <span class="material-symbols-outlined text-[18px]">mail</span>
                </span>
                <a href="mailto:info@ak-kommunal.de" class="hover:text-primary transition-colors font-medium break-words">
                  info@ak-kommunal.de
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Team Grid (Premium layout replacing the old static flow) -->
    <div class="max-w-6xl mx-auto px-8 animate-[fadeInUp_1s_ease-out_0.4s_both]">
      <h3 class="text-2xl md:text-3xl font-extrabold font-headline text-primary mb-10 pb-4 border-b border-outline-variant/20 tracking-tight">Unsere Berater & Experten</h3>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12">
        {teamMembers.map((member, index) => (
          <div class="group cursor-default flex flex-col h-full transform transition-all duration-300 hover:-translate-y-1">
            <div class="w-full aspect-[4/3] rounded-2xl overflow-hidden mb-4 bg-surface-variant/30 relative shadow-sm group-hover:shadow-lg transition-shadow duration-500">
              <img 
                src={member.image} 
                alt={member.name} 
                class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700 ease-out"
                onerror="this.src='/team/ma4-800x533.jpg'"
              />

            </div>
            <h4 class="text-xl font-extrabold font-headline text-primary tracking-tight transition-colors">{member.name}</h4>
            <p class="text-[14px] font-medium text-on-surface-variant mt-1 mb-2 leading-relaxed">{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </main>

  <FooterSection />
</Layout>
