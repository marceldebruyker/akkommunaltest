---
import Layout from '../layouts/Layout.astro';
import TopNavBar from '../components/TopNavBar.astro';
import FooterSection from '../components/FooterSection.astro';
import MembershipSection from '../components/MembershipSection.astro';
---

<Layout title="Mitglied Werden | AK Kommunal">
  <TopNavBar />
  
  <main class="w-full bg-surface pt-32 pb-24 min-h-screen relative overflow-hidden">
    <!-- Blob Background for consistency -->
    <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-primary/5 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>

    <!-- Header Section -->
    <div class="max-w-6xl mx-auto px-6 lg:px-10 relative z-10 mb-12 animate-[fadeInUp_1s_ease-out]">
      <div class="flex items-center gap-4 mb-4">
        <div class="h-[2px] w-12 bg-primary"></div>
        <h2 class="text-[10px] md:text-xs font-bold text-primary tracking-widest uppercase">
          AK Kommunal Jahresprogramm
        </h2>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold font-headline text-primary tracking-tight leading-tight pb-2 mb-6 max-w-3xl">
        Werden Sie jetzt <br/>
        <span class="text-primary-fixed-dim">Teil des Netzwerks.</span>
      </h1>
      <p class="text-on-surface-variant text-lg font-body leading-relaxed font-light max-w-2xl">
        Wählen Sie das für Sie passende Modul oder sichern Sie sich mit dem Gesamtpaket den vollen Zugriff auf das geballte Fachwissen, die Community und alle Downloads.
      </p>
    </div>

    <!-- Interactive Membership Pricing (Reusing the Component) -->
    <div class="animate-[fadeInUp_1s_ease-out_0.2s_both] relative z-10 mt-8">
      <MembershipSection />
    </div>

    <!-- Trust / FAQ Section (integrated layout instead of generic SaaS box) -->
    <div class="max-w-6xl mx-auto px-6 lg:px-10 relative z-10 mt-16 pb-12 animate-[fadeInUp_1s_ease-out_0.4s_both]">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
        <div class="lg:col-span-4">
          <div class="flex items-center gap-4 mb-4">
            <div class="h-[2px] w-12 bg-primary"></div>
            <h2 class="text-[10px] md:text-xs font-bold text-primary tracking-widest uppercase">
              Informationen
            </h2>
          </div>
          <h3 class="text-2xl md:text-3xl font-extrabold font-headline text-primary tracking-tight leading-tight">
            So funktioniert <br/>die Buchung
          </h3>
          <p class="text-on-surface-variant text-base mt-4 font-light pr-4">
            Wählen Sie oben Ihr gewünschtes Modul aus. Per Klick auf „Jetzt buchen" gelangen Sie direkt zur sicheren Abrechnung.
          </p>
        </div>
        
        <div class="lg:col-span-8 flex flex-col gap-6">
           <!-- Steps list in a more serious/institutional format -->
           <div class="bg-surface-container-lowest p-8 border border-outline-variant/30 rounded-2xl flex flex-col sm:flex-row gap-6 items-start sm:items-center">
             <div class="w-12 h-12 rounded-full border border-primary text-primary flex items-center justify-center font-bold text-lg flex-shrink-0 font-headline">1</div>
             <div>
               <h4 class="font-bold text-primary text-lg mb-1">Modul wählen & Daten hinterlegen</h4>
               <p class="text-on-surface-variant text-sm font-light leading-relaxed">Klicken Sie auf „Jetzt buchen" bei Ihrem Modul und geben Sie über unsere sichere Stripe-Schnittstelle Ihre Rechnungsdaten ein.</p>
             </div>
           </div>

           <div class="bg-surface-container-lowest p-8 border border-outline-variant/30 rounded-2xl flex flex-col sm:flex-row gap-6 items-start sm:items-center">
             <div class="w-12 h-12 rounded-full border border-primary text-primary flex items-center justify-center font-bold text-lg flex-shrink-0 font-headline">2</div>
             <div>
               <h4 class="font-bold text-primary text-lg mb-1">Zahlungsweise wählen</h4>
               <p class="text-on-surface-variant text-sm font-light leading-relaxed">Als B2B-Kunde können Sie bequem "Kauf auf Rechnung" (SEPA/Überweisung) wählen oder klassisch per Kreditkarte/PayPal bezahlen.</p>
             </div>
           </div>

           <div class="bg-surface-container-lowest p-8 border border-outline-variant/30 rounded-2xl flex flex-col sm:flex-row gap-6 items-start sm:items-center">
             <div class="w-12 h-12 rounded-full border border-primary text-primary flex items-center justify-center font-bold text-lg flex-shrink-0 font-headline">3</div>
             <div>
               <h4 class="font-bold text-primary text-lg mb-1">Sofortiger digitaler Zugang</h4>
               <p class="text-on-surface-variant text-sm font-light leading-relaxed">Direkt nach dem Abschluss wird Ihr persönlicher Zugang freigeschaltet. Sie müssen nicht auf manuelle Bestätigungen warten.</p>
             </div>
           </div>

           <div class="flex items-center gap-6 mt-4 text-xs text-on-surface-variant font-medium">
             <div class="flex items-center gap-2">
               <span class="material-symbols-outlined text-[16px] text-primary">verified</span>
               SSL-Datenübertragung
             </div>
             <div class="flex items-center gap-2">
               <span class="material-symbols-outlined text-[16px] text-primary">shield</span>
               DSGVO-konform
             </div>
           </div>
           
           <p class="text-[10px] text-on-surface-variant/70 mt-2">Alle Preise verstehen sich zzgl. gesetzlicher USt. Es gelten unsere <a href="/agb" class="text-primary hover:underline">AGB</a>.</p>
        </div>
      </div>
    </div>
  </main>

  <FooterSection />
</Layout>




<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
