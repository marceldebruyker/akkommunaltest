---
const title = "Kostenlos Registrieren - AK Kommunal Plattform";
import BrandLogo from '../components/BrandLogo.astro';
import '../styles/global.css';

const error = Astro.url.searchParams.get('error');
---

<!doctype html>
<html lang="de" class="antialiased">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <title>{title}</title>
</head>
<body class="bg-[#fafafa] font-body text-gray-800 h-screen w-full overflow-hidden flex flex-col md:flex-row">
    
    <!-- Left Panel: Graphic & Brand (Hidden on Mobile) -->
    <div class="hidden md:flex w-1/2 h-full bg-[#0a152e] relative flex-col justify-center p-16 lg:p-24 xl:p-32 overflow-hidden">
        
        <!-- Architectural Background Image -->
        <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=1400&auto=format&fit=crop" alt="Architecture Background" class="absolute inset-0 w-full h-full object-cover mix-blend-overlay opacity-50 grayscale" />
        
        <!-- Dark Blue Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-br from-[#0a152e]/90 to-[#071026]/95"></div>

        <!-- Content -->
        <div class="relative z-10 w-full max-w-lg">
            
            <div class="mb-14">
                <BrandLogo variant="light" />
            </div>

            <h1 class="text-5xl lg:text-6xl font-extrabold font-headline text-white leading-[1.05] tracking-tight pb-2 mb-8 mt-4">
                AK Kommunal<br/>Fachportal
            </h1>

            <p class="text-[17px] text-white/70 font-light leading-relaxed max-w-md mb-16">
                Legen Sie jetzt ein kostenloses Profil an, um auf die Basis-Inhalte und offenen Webinare zuzugreifen.
            </p>
            
        </div>
    </div>

    <!-- Right Panel: Register Form -->
    <div class="w-full md:w-1/2 h-full bg-[#fafafa] flex flex-col justify-center items-center relative p-6">
        
        <!-- Scrollable/Centered wrapper -->
        <div class="w-full max-w-[400px] flex flex-col">
            
            <!-- Header Texts -->
            <div class="mb-10 w-full">
                <h2 class="text-[32px] font-extrabold font-headline text-[#0a152e] tracking-tight mb-3">Konto erstellen</h2>
                <p class="text-[15px] font-light text-gray-600 leading-relaxed pr-8">
                    Erstellen Sie Ihr kostenloses Zugangskonto in wenigen Sekunden.
                </p>
            </div>

            <!-- Form Card -->
            <div class="bg-white p-8 lg:p-10 rounded-[20px] shadow-[0_8px_30px_rgb(0,0,0,0.03)] border border-gray-100 mb-8 w-full">
                
                {error && (
                    <div class="bg-red-50 text-red-600 border border-red-200 p-4 rounded-lg text-[13px] font-medium mb-6 w-full text-center flex items-center justify-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">error</span>
                        {error}
                    </div>
                )}

                <form action="/api/auth/register" method="POST" class="flex flex-col gap-6" onsubmit="this.querySelector('button[type=submit]').disabled=true; this.querySelector('button[type=submit]').innerText='Konto wird erstellt...';">
                    
                    <div class="flex gap-4">
                        <!-- Vorname -->
                        <div class="flex-1">
                            <label class="block text-[10px] font-bold text-gray-600 uppercase tracking-[0.1em] mb-2.5">
                                Vorname
                            </label>
                            <input 
                                type="text" 
                                name="first_name"
                                placeholder="Max" 
                                class="w-full bg-[#f4f4f5] border-none px-4 py-3.5 rounded-lg text-sm text-[#0a152e] font-medium outline-none focus:ring-2 focus:ring-[#0a152e]/10 transition-shadow placeholder:text-gray-400 placeholder:font-light"
                                required
                            />
                        </div>
                        <!-- Nachname -->
                        <div class="flex-1">
                            <label class="block text-[10px] font-bold text-gray-600 uppercase tracking-[0.1em] mb-2.5">
                                Nachname
                            </label>
                            <input 
                                type="text" 
                                name="last_name"
                                placeholder="Mustermann" 
                                class="w-full bg-[#f4f4f5] border-none px-4 py-3.5 rounded-lg text-sm text-[#0a152e] font-medium outline-none focus:ring-2 focus:ring-[#0a152e]/10 transition-shadow placeholder:text-gray-400 placeholder:font-light"
                                required
                            />
                        </div>
                    </div>

                    <!-- Email -->
                    <div>
                        <label class="block text-[10px] font-bold text-gray-600 uppercase tracking-[0.1em] mb-2.5">
                            E-MAIL-ADRESSE
                        </label>
                        <input 
                            type="email" 
                            name="email"
                            placeholder="name@kommune.de" 
                            class="w-full bg-[#f4f4f5] border-none px-4 py-3.5 rounded-lg text-sm text-[#0a152e] font-medium outline-none focus:ring-2 focus:ring-[#0a152e]/10 transition-shadow placeholder:text-gray-400 placeholder:font-light"
                            required
                        />
                    </div>

                    <!-- Password -->
                    <div>
                        <label class="block text-[10px] font-bold text-gray-600 uppercase tracking-[0.1em] mb-2.5">
                            GEWÜNSCHTES PASSWORT
                        </label>
                        <input 
                            type="password" 
                            name="password"
                            placeholder="Mindestens 6 Zeichen" 
                            class="w-full bg-[#f4f4f5] border-none px-4 py-3.5 rounded-lg text-sm text-[#0a152e] font-medium outline-none focus:ring-2 focus:ring-[#0a152e]/10 transition-shadow placeholder:text-gray-400 placeholder:font-light"
                            required
                        />
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="w-full bg-[#0a152e] hover:bg-[#152549] text-white font-bold py-4 rounded-lg text-[14px] tracking-wide transition-colors mt-2 disabled:opacity-50">
                        Kostenlos registrieren
                    </button>
                    
                </form>
            </div>

            <!-- Sublinks / Login Toggle -->
            <div class="text-center">
                <p class="text-[14px] text-gray-500 font-medium">
                    Bereits ein Konto vorhanden? <a href="/login" class="text-[#0a152e] hover:text-blue-600 transition-colors font-bold ml-1">Hier anmelden.</a>
                </p>
            </div>
            
        </div>
    </div>
</body>
</html>
