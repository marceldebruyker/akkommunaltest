---
import Layout from '../layouts/Layout.astro';
import TopNavBar from '../components/TopNavBar.astro';
import FooterSection from '../components/FooterSection.astro';
import BuyVideoButton from '../components/BuyVideoButton.tsx';
import { sanityClient } from '../lib/sanity';

export const prerender = false;

// Fetch Live-Events from Sanity
const rawSeminars = await sanityClient.fetch(`*[_type == "seminar" && status == "live"] | order(eventDate asc) {
  "slug": slug.current,
  title, description, moduleName, duration, price, eventDate, badges
}`);

// Group by moduleName and generate IDs for filtering
const groupedModules = Object.entries(
  rawSeminars.reduce((acc: Record<string, any[]>, seminar: any) => {
    const modName = seminar.moduleName || 'Weitere Formate';
    if (!acc[modName]) acc[modName] = [];
    acc[modName].push(seminar);
    return acc;
  }, {} as Record<string, any[]>)
).map(([moduleName, seminars]) => {
  return {
    moduleName,
    moduleId: moduleName.toLowerCase().includes('grundlagen') ? 'grundlagen' : 
              moduleName.toLowerCase().includes('spezialthemen') ? 'spezialthemen' : 
              moduleName.toLowerCase().includes('praktiker') ? 'praktiker' : 'all',
    seminars
  };
});

function getEventTopic(title: string) {
  const t = (title || '').toLowerCase();
  if (t.includes('tax cms')) return 'tax-cms';
  if (t.includes('umsatzsteuer')) return 'umsatzsteuer';
  if (t.includes('ertragsteuern')) return 'ertragsteuern';
  if (t.includes('2b ustg') || t.includes('2b')) return '2b-ustg';
  if (t.includes('aktuelles') || t.includes('jahresabschluss')) return 'aktuelles';
  return 'sonstiges';
}

function formatDate(iso: string) {
  if (!iso) return 'TBA';
  const d = new Date(iso);
  return d.toLocaleDateString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric' });
}
---

<Layout title="Termine & Live-Webinare | AK Kommunal">
  <TopNavBar />
  
  <main class="w-full bg-surface pt-32 pb-24 min-h-screen relative overflow-hidden">
    
    <!-- Abstract Background styling -->
    <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-primary/5 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>

    <!-- Header Section -->
    <div class="max-w-6xl mx-auto px-6 lg:px-10 relative z-10 mb-12 animate-[fadeInUp_1s_ease-out]">
      <div class="flex items-center gap-4 mb-4">
        <div class="h-[2px] w-12 bg-primary"></div>
        <h2 class="text-[10px] md:text-xs font-bold text-primary tracking-widest uppercase">
          AK Kommunal Akademie
        </h2>
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold font-headline text-primary tracking-tight leading-[1.1] pb-2 mb-6 max-w-3xl">
        Alle Live-Webinare <br/>
        <span class="text-primary-fixed-dim">im Überblick.</span>
      </h1>
      <p class="text-on-surface-variant text-lg font-body leading-relaxed font-light max-w-2xl">
        Praxisnahes Fachwissen für Kommunen und kommunale Gesellschaften, vermittelt von absoluten Experten. Filtern Sie nach Modul, Themen oder chronologisch.
      </p>
    </div>

    <!-- Main Content Grid -->
    <div class="max-w-6xl mx-auto px-6 lg:px-10 pb-32">
      <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">
        
        <!-- Sidebar Filters -->
        <aside class="w-full lg:w-48 flex-shrink-0">
          
          <!-- Modul Filter -->
          <div class="mb-10">
            <h3 class="text-[9px] font-bold text-on-surface-variant uppercase tracking-[0.2em] mb-5">Nach Modul</h3>
            <div class="space-y-4">
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="modul" value="all" class="filter-radio module-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" checked />
                <span class="text-[13px] font-medium text-[#05183a] group-hover:text-primary transition-colors">Alle Module</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="modul" value="grundlagen" class="filter-radio module-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Grundlagen</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="modul" value="spezialthemen" class="filter-radio module-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Spezialthemen</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="modul" value="praktiker" class="filter-radio module-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Praktiker</span>
              </label>
            </div>
          </div>
          
          <!-- Themen Filter -->
          <div class="mb-10">
            <h3 class="text-[9px] font-bold text-on-surface-variant uppercase tracking-[0.2em] mb-5">Nach Thema</h3>
            <div class="space-y-4">
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="thema" value="all" class="filter-radio topic-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" checked />
                <span class="text-[13px] font-medium text-[#05183a] group-hover:text-primary transition-colors">Alle Themen</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="thema" value="tax-cms" class="filter-radio topic-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Tax CMS</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="thema" value="umsatzsteuer" class="filter-radio topic-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Umsatzsteuer</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="thema" value="ertragsteuern" class="filter-radio topic-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Ertragsteuern</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="thema" value="2b-ustg" class="filter-radio topic-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">§ 2b UStG</span>
              </label>
              <label class="flex items-center gap-3 cursor-pointer group">
                <input type="radio" name="thema" value="aktuelles" class="filter-radio topic-radio w-3.5 h-3.5 border-outline-variant/40 text-primary focus:ring-primary cursor-pointer accent-[#05183a]" />
                <span class="text-[13px] font-light text-[#05183a] group-hover:text-primary transition-colors">Aktuelles & Updates</span>
              </label>
            </div>
          </div>
        </aside>

        <!-- Seminar List -->
        <div class="flex-1 space-y-12" id="seminar-list">
          {groupedModules.map((module) => (
            <div class="module-group" data-module={module.moduleId}>
              <h2 class="text-2xl font-bold font-headline text-primary mb-6 flex items-center gap-3">
                <span class="w-2 h-2 rounded-full bg-primary-fixed-dim"></span>
                {module.moduleName}
              </h2>
              <div class="space-y-4">
                {(module.seminars as any[]).map((seminar: any) => (
                    <div class="seminar-card flex flex-col items-start md:flex-row md:items-stretch gap-5 p-6 md:p-8 bg-surface-container-lowest border border-outline-variant/30 rounded-2xl hover:border-primary/30 hover:shadow-md transition-all group" data-module-id={module.moduleId} data-topic-id={getEventTopic(seminar.title)}>
                      
                      <!-- Events Block -->
                      <div class="md:w-56 shrink-0 relative flex flex-col justify-center border-b md:border-b-0 md:border-r border-outline-variant/15 pb-4 md:pb-0 md:pr-6">
                        <span class="text-[10px] text-on-surface-variant/70 uppercase tracking-widest font-black mb-3 block">Datum</span>
                        <div class="text-xl md:text-2xl font-black text-primary font-headline tracking-tight group-hover:text-primary-fixed-dim transition-colors">
                          {formatDate(seminar.eventDate)}
                        </div>
                      </div>
                      
                      <!-- Context & Topic -->
                      <div class="flex-grow flex flex-col justify-center py-2 md:pl-2">
                         <h3 class="text-lg md:text-xl font-bold text-primary leading-snug mb-1">{seminar.title}</h3>
                         <div class="text-[13px] font-bold text-primary-fixed-dim mb-2">{seminar.moduleName}</div>
                         {seminar.description && (
                           <p class="text-[14px] text-on-surface-variant font-light leading-relaxed">
                             {seminar.description}
                           </p>
                         )}
                      </div>
                      
                      <!-- Meta & Action -->
                      <div class="w-full md:w-auto md:text-right shrink-0 mt-4 md:mt-0 flex flex-row md:flex-col items-center justify-between md:justify-center gap-4 md:pl-6 md:min-w-[140px]">
                         <div class="text-[11px] font-bold text-secondary flex items-center gap-1.5 uppercase tracking-widest bg-secondary/5 px-2.5 py-1 rounded-md">
                           <span class="material-symbols-outlined text-[14px]">schedule</span> 
                           {seminar.duration || '90 Min.'}
                         </div>
                         <div class="w-full md:w-auto">
                            <BuyVideoButton client:load video={{ id: seminar.slug, title: seminar.title, price: seminar.price || 0 }} />
                         </div>
                      </div>
                      
                    </div>
                ))}
              </div>
            </div>
          ))}
          
          <!-- Empty State -->
          <div id="empty-state" class="hidden text-center py-16 text-on-surface-variant bg-surface-container-lowest rounded-2xl border border-outline-variant/20 border-dashed">
            <div class="material-symbols-outlined text-4xl text-outline-variant/50 mb-3">event_busy</div>
            <h3 class="text-lg font-bold text-primary mb-1">Keine Seminare gefunden</h3>
            <p class="text-sm font-light">Für diese Filterkombination gibt es aktuell keine Termine.</p>
          </div>
        </div>
        
      </div>
    </div>
  </main>

  <FooterSection />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const seminarCards = document.querySelectorAll('.seminar-card');
    const emptyState = document.getElementById('empty-state');

    function updateFilters() {
      // Find active values relying on standard DOM queries
      let currentModule = 'all';
      let currentTopic = 'all';
      
      const activeModuleRadio = document.querySelector('input.module-radio:checked');
      if (activeModuleRadio) {
        currentModule = activeModuleRadio.getAttribute('value') || 'all';
      }
      
      const activeTopicRadio = document.querySelector('input.topic-radio:checked');
      if (activeTopicRadio) {
        currentTopic = activeTopicRadio.getAttribute('value') || 'all';
      }

      // Update styling tags for active/inactive text
      document.querySelectorAll<HTMLInputElement>('input.filter-radio').forEach((r) => {
        const textSpan = r.nextElementSibling;
        if (!textSpan) return;
        
        if (r.checked || r.hasAttribute('checked')) {
          textSpan.classList.remove('font-light');
          textSpan.classList.add('font-medium');
        } else {
          textSpan.classList.add('font-light');
          textSpan.classList.remove('font-medium');
        }
      });

      let visibleCount = 0;
      seminarCards.forEach(card => {
        const cardModule = card.getAttribute('data-module-id');
        const cardTopic = card.getAttribute('data-topic-id');
        
        const moduleMatch = (currentModule === 'all' || cardModule === currentModule);
        const topicMatch = (currentTopic === 'all' || cardTopic === currentTopic);
        
        if (moduleMatch && topicMatch) {
          card.setAttribute('style', 'display: flex;');
          card.classList.add('is-visible');
          visibleCount++;
        } else {
          card.setAttribute('style', 'display: none;');
          card.classList.remove('is-visible');
        }
      });
      
      // Hide modules that have no visible cards
      document.querySelectorAll('.module-group').forEach(group => {
        const visibleCardsInGroup = group.querySelectorAll('.seminar-card.is-visible');
        if (visibleCardsInGroup.length === 0) {
          group.setAttribute('style', 'display: none;');
        } else {
          group.setAttribute('style', 'display: block;');
        }
      });
      
      if (emptyState) {
        if (visibleCount === 0) emptyState.classList.remove('hidden');
        else emptyState.classList.add('hidden');
      }
    }

    // Attach event listeners to radios
    document.querySelectorAll('input.filter-radio').forEach(r => {
      r.addEventListener('change', updateFilters);
    });
  });
</script>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
