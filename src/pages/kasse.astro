---
import Layout from '../layouts/Layout.astro';
import TopNavBar from '../components/TopNavBar.astro';
import FooterSection from '../components/FooterSection.astro';
import CheckoutFlow from '../components/CheckoutFlow.tsx';
import { getSupabaseServer } from '../lib/supabase';

const { data } = await getSupabaseServer(Astro.request, Astro.cookies).auth.getUser();
const user = data?.user || null;
---

<Layout title="Kasse | AK Kommunal">
  <TopNavBar />
  
  <main class="w-full bg-surface pt-32 pb-24 min-h-screen relative overflow-hidden">
    <!-- Blob Backgrounds -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-primary/5 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-[800px] h-[800px] bg-secondary-fixed/20 rounded-full blur-[120px] translate-y-1/3 -translate-x-1/3 pointer-events-none"></div>

    <!-- Header Section -->
    <div class="max-w-6xl mx-auto px-6 lg:px-10 relative z-10 mb-2">
      <div class="flex items-center gap-4 mb-4">
        <div class="h-[2px] w-12 bg-primary"></div>
        <h2 class="text-[10px] md:text-xs font-bold text-primary tracking-widest uppercase">
          Sicherer Checkout
        </h2>
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold font-headline text-primary tracking-tight leading-tight pb-2 max-w-3xl">
        Schließen Sie Ihre <br/>
        <span class="text-primary-fixed-dim">Buchung ab.</span>
      </h1>
    </div>

    <!-- React Checkout App Island -->
    <CheckoutFlow client:only="react" user={user} />

  </main>

  <FooterSection />
</Layout>
