---
import Layout from '../layouts/Layout.astro';
import TopNavBar from '../components/TopNavBar.astro';

const error = Astro.url.searchParams.get('error');
const success = Astro.url.searchParams.get('success');
---

<Layout title="Passwort vergessen | AK Kommunal">
    <TopNavBar />
    
    <div class="h-screen w-full flex bg-[#f8f9fa]">
        <!-- Left Side: Interactive Portal Display -->
        <div class="hidden lg:flex w-1/2 bg-[#05183a] relative overflow-hidden items-center justify-center p-12">
            <!-- Background Elements -->
            <div class="absolute inset-0 opacity-20">
                <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-white/10 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3"></div>
                <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-blue-500/20 rounded-full blur-[100px] translate-y-1/3 -translate-x-1/4"></div>
            </div>

            <!-- Geometric Grid Pattern -->
            <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.05) 1px, transparent 0); background-size: 32px 32px;"></div>

            <!-- Content Area -->
            <div class="relative z-10 w-full max-w-lg">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/10 border border-white/10 text-white/80 text-xs font-medium mb-8 backdrop-blur-md">
                    <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse"></span>
                    Sicheres Portal
                </div>
                
                <h2 class="text-4xl lg:text-5xl font-bold text-white leading-[1.1] mb-6 font-headline">
                    Passwort<br/>wiederherstellen
                </h2>
                <p class="text-white/60 text-lg leading-relaxed max-w-md font-light">
                    Wir senden Ihnen einen Link zu, mit dem Sie sich wieder sicher in Ihr Dashboard und Fachportal einloggen können.
                </p>
                
                <!-- Trust Indicators -->
                <div class="mt-12 flex gap-8 border-t border-white/10 pt-8">
                    <div>
                        <div class="text-2xl font-bold text-white mb-1">100%</div>
                        <div class="text-xs text-white/50 uppercase tracking-wider font-semibold">Datenschutz</div>
                    </div>
                    <div>
                        <div class="text-2xl font-bold text-white mb-1">24/7</div>
                        <div class="text-xs text-white/50 uppercase tracking-wider font-semibold">Erreichbarkeit</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Side: Reset Form -->
        <div class="w-full lg:w-1/2 flex items-center justify-center p-8 sm:p-12 relative">
            <div class="w-full max-w-md">
                <a href="/login" class="text-gray-500 hover:text-[#0a152e] mb-8 inline-flex items-center gap-2 text-[11px] font-bold uppercase tracking-[0.1em] transition-colors">
                    <span class="material-symbols-outlined text-[16px]">arrow_back</span>
                    Zurück zum Login
                </a>

                <!-- Header -->
                <div class="mb-10">
                    <h1 class="text-3xl sm:text-4xl font-extrabold text-[#0a152e] font-headline mb-3 tracking-tight">Neues Passwort</h1>
                    <p class="text-gray-500 text-[15px] leading-relaxed">
                        Bitte geben Sie Ihre E-Mail-Adresse ein. Wir senden Ihnen im Anschluss eine E-Mail mit einem Bestätigungslink.
                    </p>
                </div>

                <!-- Error Messages -->
                {error && (
                    <div class="bg-red-50 text-red-600 p-4 border-l-4 border-red-600 rounded-r-lg text-sm mb-6 flex items-start gap-3 shadow-sm">
                        <span class="material-symbols-outlined shrink-0 mt-0.5">error</span>
                        {error}
                    </div>
                )}
                <!-- Success Message -->
                {success && (
                    <div class="bg-emerald-50 text-emerald-700 p-4 border-l-4 border-emerald-500 rounded-r-lg text-sm mb-6 flex items-start gap-3 shadow-sm">
                        <span class="material-symbols-outlined shrink-0 mt-0.5 text-emerald-500">check_circle</span>
                        Falls Ihre E-Mail registriert ist, haben wir Ihnen soeben einen Bestätigungslink gesendet. (Bitte prüfen Sie auch den Spam-Ordner).
                    </div>
                )}

                <form action="/api/auth/reset-request" method="POST" class="flex flex-col gap-6">
                    
                    <!-- Email -->
                    <div>
                        <label class="block text-[10px] font-bold text-gray-600 uppercase tracking-[0.1em] mb-2.5">
                            E-MAIL-ADRESSE
                        </label>
                        <input 
                            type="email" 
                            name="email"
                            placeholder="name@kommune.de" 
                            class="w-full bg-[#f4f4f5] border-none px-4 py-3.5 rounded-lg text-sm text-[#0a152e] font-medium outline-none focus:ring-2 focus:ring-[#0a152e]/10 transition-shadow placeholder:text-gray-400 placeholder:font-light"
                            required
                        />
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" class="w-full mt-2 bg-[#0a152e] hover:bg-[#112147] text-white py-4 px-6 rounded-lg text-[11px] font-bold uppercase tracking-[0.15em] transition-colors flex items-center justify-center gap-3 group shadow-md shadow-[#0a152e]/10">
                        LINK ZUSENDEN
                        <span class="material-symbols-outlined text-[16px] group-hover:translate-x-1 transition-transform">mail</span>
                    </button>

                </form>
            </div>
        </div>
    </div>
</Layout>
