---
import Layout from '../layouts/Layout.astro';
import TopNavBar from '../components/TopNavBar.astro';

// Wir laden die Supabase Konfiguration für den Frontend-Client ein,
// da das Hash-Token (#access_token=...) nur im Browser via JS auslesbar ist.
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<Layout title="Neues Passwort setzen | AK Kommunal">
    <TopNavBar />
    
    <div class="h-screen w-full flex bg-[#f8f9fa] items-center justify-center p-6">
        <div class="w-full max-w-md bg-white p-8 sm:p-12 rounded-2xl shadow-xl shadow-[#05183a]/5 relative">
            
            <h1 class="text-3xl font-extrabold text-[#0a152e] font-headline mb-3 tracking-tight">Neues Passwort</h1>
            <p class="text-gray-500 text-[14px] leading-relaxed mb-10 border-b border-gray-100 pb-10">
                Bitte vergeben Sie Ihr neues, sicheres Passwort. Sie werden nach der erfolgreichen Änderung automatisch in Ihr Dashboard weitergeleitet.
            </p>

            <div id="alert-error" class="hidden bg-red-50 text-red-600 p-4 border-l-4 border-red-600 rounded-r-lg text-sm mb-6 items-start gap-3 shadow-sm">
                <span class="material-symbols-outlined shrink-0 mt-0.5">error</span>
                <span id="error-msg"></span>
            </div>

            <div id="alert-success" class="hidden bg-emerald-50 text-emerald-700 p-4 border-l-4 border-emerald-500 rounded-r-lg text-sm mb-6 items-start gap-3 shadow-sm">
                <span class="material-symbols-outlined shrink-0 mt-0.5 text-emerald-500">check_circle</span>
                Passwort erfolgreich geändert! Leite weiter...
            </div>

            <form id="reset-password-form" class="flex flex-col gap-6">
                <!-- New Password -->
                <div>
                    <label class="block text-[10px] font-bold text-gray-600 uppercase tracking-[0.1em] mb-2.5">
                        NEUES PASSWORT
                    </label>
                    <input 
                        type="password" 
                        id="new-password"
                        placeholder="Mindestens 8 Zeichen" 
                        class="w-full bg-[#f4f4f5] border-none px-4 py-3.5 rounded-lg text-sm text-[#0a152e] font-medium outline-none focus:ring-2 focus:ring-[#0a152e]/10 transition-shadow placeholder:text-gray-400 placeholder:font-light"
                        required
                        minlength="8"
                    />
                </div>

                <button type="submit" id="submit-btn" class="w-full mt-4 bg-[#0a152e] hover:bg-[#112147] text-white py-4 px-6 rounded-lg text-[11px] font-bold uppercase tracking-[0.15em] transition-colors flex items-center justify-center gap-3 group shadow-md shadow-[#0a152e]/10">
                    <span>PASSWORT SPEICHERN</span>
                    <span class="material-symbols-outlined text-[16px] group-hover:translate-x-1 transition-transform">lock_reset</span>
                </button>
            </form>
            
        </div>
    </div>
</Layout>

<script is:inline type="module">
    // Mache Supabase clientseitig verfügbar (wir holen die offizielle Bibliothek via CDN für maximale Astro-Kompatibilität auf rein statischen Pages)
    import { createClient } from "https://cdn.jsdelivr.net/npm/@supabase/supabase-js/+esm";

    document.addEventListener('DOMContentLoaded', () => {
        // Die Env-Variablen sind zur Buildzeit vom Astro Compiler injiziert worden (Vercel Build Prozess)
        // Aber `is:inline` kann import.meta.env nicht auflösen.
        // Wait, inline scripts can't resolve meta env. We need standard non-inline module format!
    });
</script>

<script>
    import { createBrowserClient } from '@supabase/ssr';
    
    // Using standard Astro Client script block to get env variables properly bundled.
    const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
    const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
    const supabase = createBrowserClient(supabaseUrl, supabaseAnonKey);

    const form = document.getElementById('reset-password-form');
    const input = document.getElementById('new-password');
    const btn = document.getElementById('submit-btn');
    const alertError = document.getElementById('alert-error');
    const errorMsg = document.getElementById('error-msg');
    const alertSuccess = document.getElementById('alert-success');

    if (form && input && btn) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            // UI Update
            btn.classList.add('opacity-50', 'pointer-events-none');
            const btnSpan = btn.querySelector('span');
            if (btnSpan) btnSpan.textContent = 'WIRD GESPEICHERT...';
            if (alertError) alertError.classList.add('hidden');

            const newPassword = (input as HTMLInputElement).value;

            try {
                // Supabase Browser-Client hat im Hintergrund automatisch das Token aus der URL extrahiert und die lokale Session validiert.
                const { error, data } = await supabase.auth.updateUser({
                    password: newPassword
                });

                if (error) {
                    throw error;
                }

                // Success
                if (alertSuccess) {
                    alertSuccess.classList.remove('hidden');
                    alertSuccess.classList.add('flex');
                }
                
                // Kurze Verzögerung für visuelles Feedback, dann redirect ins Zentrum der Macht
                setTimeout(() => {
                    window.location.href = '/app/dashboard';
                }, 1500);

            } catch (err: any) {
                if (alertError && errorMsg) {
                    alertError.classList.remove('hidden');
                    alertError.classList.add('flex');
                    errorMsg.textContent = err.message || 'Ein unbekannter Fehler ist aufgetreten. Token vielleicht abgelaufen?';
                }
                
                // Reset Button
                btn.classList.remove('opacity-50', 'pointer-events-none');
                if (btnSpan) btnSpan.textContent = 'PASSWORT SPEICHERN';
            }
        });
    }
</script>
