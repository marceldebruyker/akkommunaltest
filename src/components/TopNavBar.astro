---
import BrandLogo from './BrandLogo.astro';
import CartIcon from './CartIcon.tsx';
---
<nav class="fixed top-0 w-full z-50 bg-white/98 dark:bg-[#05183a]/95 backdrop-blur-xl border-b border-gray-100 dark:border-white/5 transition-all duration-300">
  <div class="flex items-center justify-between px-6 lg:px-10 py-3.5 max-w-6xl mx-auto">
    
    <!-- Left: Brand Logo -->
    <div class="flex-shrink-0">
      <BrandLogo />
    </div>
    
    <!-- Center: Navigation Links (Desktop only) -->
    <div class="hidden lg:flex items-center gap-1">
      <a class="px-4 py-2 rounded-full font-headline font-bold text-[15px] tracking-tight text-[#475569] hover:text-[#0f172a] hover:bg-slate-50 dark:text-gray-400 dark:hover:text-white dark:hover:bg-white/5 transition-all" href="/mediathek">Mediathek</a>
      <a class="px-4 py-2 rounded-full font-headline font-bold text-[15px] tracking-tight text-[#475569] hover:text-[#0f172a] hover:bg-slate-50 dark:text-gray-400 dark:hover:text-white dark:hover:bg-white/5 transition-all" href="/aktuelles">Aktuelles</a>
      <a class="px-4 py-2 rounded-full font-headline font-bold text-[15px] tracking-tight text-[#475569] hover:text-[#0f172a] hover:bg-slate-50 dark:text-gray-400 dark:hover:text-white dark:hover:bg-white/5 transition-all" href="/termine">Termine</a>
      <a class="px-4 py-2 rounded-full font-headline font-bold text-[15px] tracking-tight text-[#475569] hover:text-[#0f172a] hover:bg-slate-50 dark:text-gray-400 dark:hover:text-white dark:hover:bg-white/5 transition-all" href="/team">Personen</a>
      <a class="px-4 py-2 rounded-full font-headline font-bold text-[15px] tracking-tight text-[#475569] hover:text-[#0f172a] hover:bg-slate-50 dark:text-gray-400 dark:hover:text-white dark:hover:bg-white/5 transition-all" href="/kontakt">Kontakt</a>
    </div>
    
    <!-- Right: Actions -->
    <div class="flex items-center gap-6 lg:gap-8">
      
      <!-- Desktop Actions -->
      <div class="hidden lg:flex items-center gap-3">
        <!-- Mitglied werden -->
        <a href="/mitglied-werden" class="flex items-center gap-1.5 font-headline font-bold text-[14px] text-white bg-primary hover:bg-primary-fixed-dim px-6 py-2.5 rounded-full transition-all shadow-md hover:-translate-y-0.5 hover:shadow-lg">
          Mitglied werden
        </a>
        
        <!-- Divider -->
        <div class="h-6 w-[1px] bg-slate-200 dark:bg-white/10 mx-2"></div>
        
        <!-- Cart Icon -->
        <CartIcon client:load />

        <!-- Login -->
        <a href="/login" class="flex items-center justify-center w-10 h-10 bg-slate-50 hover:bg-slate-100 rounded-full border border-slate-100/50 text-[#475569] hover:text-[#0f172a] dark:bg-white/5 dark:hover:bg-white/10 dark:text-slate-300 dark:border-white/5 transition-all shadow-sm group" aria-label="Login">
          <span class="material-symbols-outlined text-[18px] group-hover:translate-x-0.5 transition-transform">login</span>
        </a>
      </div>
      
      <!-- Hamburger (Mobile only) -->
      <button id="mobile-menu-toggle" class="lg:hidden flex items-center justify-center w-10 h-10 bg-slate-50 border border-slate-100/50 rounded-full text-[#475569] hover:bg-slate-100 dark:bg-white/5 dark:hover:bg-white/10 dark:text-slate-300 transition-all shadow-sm" aria-label="Menü öffnen">
        <span class="material-symbols-outlined text-[24px]">menu</span>
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown (hidden by default, only below lg) -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 dark:border-white/10">
    <div class="flex flex-col px-6 py-4 gap-1 max-w-6xl mx-auto">
      <a class="font-body font-semibold text-[15px] text-[#475569] hover:text-[#0f172a] hover:bg-gray-50 dark:hover:bg-white/5 rounded-xl px-4 py-3 transition-all flex items-center justify-between" href="/mediathek">
        Mediathek
        <span class="material-symbols-outlined text-[18px] text-gray-300">chevron_right</span>
      </a>
      <a class="font-body font-semibold text-[15px] text-[#475569] hover:text-[#0f172a] hover:bg-gray-50 dark:hover:bg-white/5 rounded-xl px-4 py-3 transition-all flex items-center justify-between" href="/aktuelles">
        Aktuelles
        <span class="material-symbols-outlined text-[18px] text-gray-300">chevron_right</span>
      </a>
      <a class="font-body font-semibold text-[15px] text-[#475569] hover:text-[#0f172a] hover:bg-gray-50 dark:hover:bg-white/5 rounded-xl px-4 py-3 transition-all flex items-center justify-between" href="/termine">
        Termine
        <span class="material-symbols-outlined text-[18px] text-gray-300">chevron_right</span>
      </a>
      <a class="font-body font-semibold text-[15px] text-[#475569] hover:text-[#0f172a] hover:bg-gray-50 dark:hover:bg-white/5 rounded-xl px-4 py-3 transition-all flex items-center justify-between" href="/team">
        Personen
        <span class="material-symbols-outlined text-[18px] text-gray-300">chevron_right</span>
      </a>
      <a class="font-body font-semibold text-[15px] text-[#475569] hover:text-[#0f172a] hover:bg-gray-50 dark:hover:bg-white/5 rounded-xl px-4 py-3 transition-all flex items-center justify-between" href="/kontakt">
        Kontakt
        <span class="material-symbols-outlined text-[18px] text-gray-300">chevron_right</span>
      </a>
      <div class="mt-2 pt-2 border-t border-gray-100 dark:border-white/10">
        <a href="/mitglied-werden" class="flex items-center justify-center w-full font-body font-bold text-[15px] text-white bg-primary hover:bg-primary-fixed-dim rounded-xl px-4 py-3 transition-all shadow-sm">
          Mitglied werden
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    
    if (toggleBtn && menu) {
      toggleBtn.addEventListener('click', () => {
        const isHidden = menu.classList.toggle('hidden');
        const icon = toggleBtn.querySelector('.material-symbols-outlined');
        if (icon) icon.textContent = isHidden ? 'menu' : 'close';
      });
    }
  });
</script>
