<section class="py-24 md:py-32 bg-primary text-on-primary overflow-hidden relative">
  <!-- Dynamic Background Shape -->
  <div class="absolute top-0 right-0 w-full md:w-1/2 h-full bg-primary-container opacity-40 transform skew-x-12 translate-x-20 rounded-l-[100px]"></div>
  <div class="absolute -bottom-32 -left-32 w-64 h-64 bg-primary-fixed-dim/10 rounded-full blur-[100px]"></div>
  
  <div class="max-w-6xl mx-auto px-8 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/20 text-[10px] sm:text-xs font-bold tracking-wider uppercase mb-6 backdrop-blur-sm">
          <span class="w-2 h-2 rounded-full bg-primary-fixed-dim animate-pulse"></span>
          Live Community
        </div>
        
        <h2 class="text-3xl md:text-4xl font-extrabold font-headline tracking-tight mb-6 leading-tight">
          Experten-Diskussionen &amp; Netzwerken
        </h2>
        <p class="text-lg md:text-xl text-on-primary-container mb-10 leading-relaxed font-light">
          Werden Sie Teil der AK Kommunal Community. Tauschen Sie sich mit Fachkollegen aus, stellen Sie Fragen an unsere Experten von <span class="font-semibold text-white">BW PARTNER</span> und partizipieren Sie an exklusiven Webinaren.
        </p>
        
        <ul class="space-y-5 mb-12">
          <li class="flex items-start gap-4 p-4 rounded-xl hover:bg-white/5 transition-colors border border-transparent hover:border-white/10 group cursor-default">
            <span class="material-symbols-outlined text-primary-fixed-dim bg-white/10 p-2 rounded-lg group-hover:scale-110 transition-transform">check_circle</span>
            <div>
              <h4 class="font-bold text-lg mb-1">Direkter Draht zu BW PARTNER Experten</h4>
              <p class="text-on-primary-container text-sm">Erhalten Sie verbindliche Antworten auf Ihre fachspezifischen Fragen.</p>
            </div>
          </li>
          <li class="flex items-start gap-4 p-4 rounded-xl hover:bg-white/5 transition-colors border border-transparent hover:border-white/10 group cursor-default">
            <span class="material-symbols-outlined text-primary-fixed-dim bg-white/10 p-2 rounded-lg group-hover:scale-110 transition-transform">forum</span>
            <div>
              <h4 class="font-bold text-lg mb-1">Geschlossene Fachforen</h4>
              <p class="text-on-primary-container text-sm">Ein sicherer Raum für Entscheider zum Austausch von Best Practices.</p>
            </div>
          </li>
          <li class="flex items-start gap-4 p-4 rounded-xl hover:bg-white/5 transition-colors border border-transparent hover:border-white/10 group cursor-default">
            <span class="material-symbols-outlined text-primary-fixed-dim bg-white/10 p-2 rounded-lg group-hover:scale-110 transition-transform">record_voice_over</span>
            <div>
              <h4 class="font-bold text-lg mb-1">Live-Q&amp;A Sessions</h4>
              <p class="text-on-primary-container text-sm">Regelmäßige digitale Treffen zu aktuellen Gesetzesänderungen.</p>
            </div>
          </li>
        </ul>
        
        <a href="/forum" class="inline-flex items-center justify-center bg-white text-primary px-10 py-4 rounded-lg font-bold hover:bg-primary-fixed-dim hover:-translate-y-1 transition-all duration-300 shadow-xl hover:shadow-2xl text-lg">
          Zum Forum beitreten
        </a>
      </div>
      
      <!-- Mockup of the Forum -->
      <div class="glass-card p-6 md:p-8 rounded-3xl border border-white/20 shadow-[-20px_20px_60px_-15px_rgba(0,0,0,0.3)] relative">
        <div class="absolute -top-4 -right-4 bg-primary-fixed-dim text-primary text-xs font-bold px-4 py-2 rounded-full shadow-lg transform rotate-3">
          14 neue Beiträge
        </div>
        
        <div class="space-y-5">
          <!-- Post 1 -->
          <div class="flex gap-4 p-5 rounded-2xl bg-white/10 border border-white/10 hover:bg-white/15 transition-colors">
            <div class="w-12 h-12 shrink-0 rounded-full bg-primary-fixed-dim flex items-center justify-center text-primary font-extrabold text-lg shadow-inner">MK</div>
            <div>
              <div class="flex items-center justify-between mb-1">
                <h5 class="font-bold text-white">Markus K.</h5>
                <span class="text-xs font-medium text-white/50 bg-black/20 px-2 py-0.5 rounded-full">Vor 2 Std.</span>
              </div>
              <p class="text-sm text-on-primary-container leading-relaxed">Wie handhabt ihr die neue Richtlinie zur Energieeffizienz in öffentlichen Gebäuden? Gibt es schon erste Vorlagen?</p>
            </div>
          </div>
          
          <!-- Post 2 Reply -->
          <div class="flex gap-4 p-5 rounded-2xl bg-primary-container border border-primary-fixed-dim/30 ml-6 md:ml-12 relative shadow-lg">
            <div class="absolute -left-5 top-8 w-4 h-[2px] bg-white/20"></div>
            <div class="absolute -left-5 -top-4 w-[2px] h-[calc(100%+0px)] bg-white/20"></div>
            
            <div class="w-12 h-12 shrink-0 rounded-full bg-white flex items-center justify-center text-primary font-extrabold text-lg shadow-inner border-2 border-primary-fixed-dim">BW</div>
            <div>
              <div class="flex items-center justify-between mb-1">
                <h5 class="font-bold text-white flex items-center gap-2">
                  BW PARTNER Expert
                  <span class="material-symbols-outlined text-[14px] text-primary-fixed-dim" title="Verifizierter Experte">verified</span>
                </h5>
                <span class="text-xs font-medium text-white/50 bg-black/20 px-2 py-0.5 rounded-full">Vor 45 Min.</span>
              </div>
              <p class="text-sm text-on-primary-container leading-relaxed">Guten Morgen Markus, in unserem neuesten Whitepaper im Mitgliederbereich haben wir die 5 wichtigsten Schritte zusammengefasst. Zudem gibt es hier den Link zur Muster-Vorabeit...</p>
            </div>
          </div>
          
          <!-- Post 3 Reply -->
          <div class="flex gap-4 p-5 rounded-2xl bg-white/10 border border-white/10 hover:bg-white/15 transition-colors ml-6 md:ml-12 relative">
             <div class="absolute -left-5 top-8 w-4 h-[2px] bg-white/20"></div>
             
            <div class="w-12 h-12 shrink-0 rounded-full bg-tertiary-fixed flex items-center justify-center text-tertiary font-extrabold text-lg shadow-inner">SL</div>
            <div>
               <div class="flex items-center justify-between mb-1">
                <h5 class="font-bold text-white">Sabine L.</h5>
                <span class="text-xs font-medium text-white/50 bg-black/20 px-2 py-0.5 rounded-full">Vor 10 Min.</span>
              </div>
              <p class="text-sm text-on-primary-container leading-relaxed">Danke für den Hinweis! Sehr hilfreich für unsere nächste Stadtratssitzung morgen Abend.</p>
            </div>
          </div>
        </div>
        
        <div class="mt-6 pt-6 border-t border-white/10">
           <div class="flex items-center gap-4 bg-black/20 p-2 rounded-xl border border-white/10">
              <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center"><span class="material-symbols-outlined text-[16px]">person</span></div>
              <div class="text-sm text-white/40 flex-1">Schreibe eine Antwort...</div>
              <button class="w-8 h-8 rounded-lg bg-primary-fixed-dim text-primary flex items-center justify-center hover:bg-white transition-colors"><span class="material-symbols-outlined text-[16px]">send</span></button>
           </div>
        </div>
      </div>
    </div>
  </div>
</section>
