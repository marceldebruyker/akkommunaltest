---
// src/components/BWPartnerSection.astro
---

<section class="py-16 md:py-20 bg-white relative border-t border-outline-variant/10">
  <div class="max-w-6xl mx-auto px-6 lg:px-10">
    <div class="flex flex-col items-center text-center max-w-2xl mx-auto">
      
      <!-- "Eine Marke von" + BW Partner Logo -->
      <span class="text-[10px] font-semibold text-[#94a3b8] tracking-[0.25em] uppercase font-label mb-3">Eine Marke von</span>
      <img 
        src="/team/65c525d3e0e09bd7fe7f79ce_BW-Partner-Logo.svg" 
        alt="BW Partner" 
        class="h-10 md:h-12 mb-8"
      />
      
      <!-- Single elegant line -->
      <p class="text-[15px] md:text-[16px] text-[#64748b] font-body leading-relaxed max-w-md">
        Seit über 70 Jahren bündelt <span class="font-semibold text-[#334155]">BW PARTNER</span> das Know-how einer umfassenden Gesamtbetreuung rund um Steuern, Beratung und Prüfung.
      </p>
      
      <!-- Subtle link -->
      <a 
        href="https://www.bw-partner.com/" 
        target="_blank" 
        rel="noopener noreferrer" 
        class="mt-6 inline-flex items-center gap-1.5 text-[13px] font-semibold text-[#94a3b8] hover:text-[#002C58] transition-colors group"
      >
        bw-partner.com
        <span class="material-symbols-outlined text-[16px] group-hover:translate-x-0.5 transition-transform">arrow_forward</span>
      </a>
      
    </div>
  </div>
</section>
