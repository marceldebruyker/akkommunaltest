---
// src/components/BrandLogo.astro
// `variant`  : 'dark' (default, for light bg) or 'light' (for dark bg)
// `subtitle` : show the "Eine Marke von BW Partner" tagline. Default true
//              so footer/auth pages keep it; pass false in the top nav
//              where a one-line wordmark reads cleaner.
const { variant = 'dark', subtitle = true } = Astro.props;

const textColor = variant === 'light' ? 'text-white' : 'text-[#05183a]';
const subtitleColor = variant === 'light' ? 'text-white/50' : 'text-[#878787]';
---

<a href="/" class="flex items-center gap-3 group cursor-pointer decoration-transparent">
  
  <!-- Original BW Partner Lion Shield (exact SVG paths from brand asset) -->
  <div class="relative w-7 h-7 flex items-center justify-center flex-shrink-0 group-hover:scale-105 transition-transform duration-500 will-change-transform">
    <svg viewBox="0 0 38.8 38.8" class="w-full h-full">
      <!-- White background square -->
      <rect fill={variant === 'light' ? '#ffffff' : '#FFF'} width="38.8" height="38.8"/>
      <!-- Lion in dark blue -->
      <path fill="#002C58" d="M21.8 8.9c0-.5-.5-.9-1-.9s-.9.5-.9 1 .5.9 1 .9c.5-.1.9-.5.9-1zM5.2 13.7C6.2 11.5 8.3 9 8.3 9s-.7-3.1-.2-3.6c.5-.5 3.6 1.7 3.6 1.7s2.5-1 6.2-1 10.9 2.7 10.9 2.7L27.5 14c-.4-.3-.8-.4-1.3-.4-1.2 0-2.2 1-2.2 2.2 0 1.2 1 2.2 2.2 2.2h.3l-.5 2s-.1.7-1.1.9c-.9.2-4.2-1.1-4.2-1.1v3.9L32.1 21v-.1c.7-1.8 2.5-3.1 4.6-3.1.7 0 1.4.1 2 .4V.1H0v21.2c1.9-.6 3.1-1.1 3.1-1.1s1.1-4.3 2.1-6.5zm14.6 21.5l5.3 3.7h13.8V22.5l-3.1 1.2-16 11.5z"/>
    </svg>
  </div>
  
  <!-- Typography -->
  <div class="flex flex-col justify-center">
    <span class={`text-[21px] font-extrabold font-headline ${textColor} leading-none tracking-tight`}>
      AK Kommunal
    </span>
    {subtitle && (
      <span class={`text-[8px] font-normal ${subtitleColor} uppercase tracking-[0.18em] mt-[3px] leading-none`} style="font-stretch: condensed; letter-spacing: 0.18em;">
        Eine Marke von BW Partner
      </span>
    )}
  </div>

</a>
