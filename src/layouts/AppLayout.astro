---
import '../styles/global.css';
import BrandLogo from '../components/BrandLogo.astro';
import { getSupabaseServer } from '../lib/supabase';

const { title, currentPath } = Astro.props;

const supabase = getSupabaseServer(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();

const email = user?.email || 'Gast';
const firstName = user?.user_metadata?.first_name || '';
const lastName = user?.user_metadata?.last_name || '';
const salutationString = user?.user_metadata?.salutation_string || '';
const displayName = salutationString || (lastName ? `Herr/Frau ${lastName}` : (firstName ? `${firstName} ${lastName}` : email));
const initials = firstName ? `${firstName.charAt(0)}${lastName?.charAt(0) || ''}` : email.charAt(0).toUpperCase();

let isAdmin = false;
if (user) {
  const { data: profile } = await supabase
    .from('user_profiles')
    .select('is_admin')
    .eq('id', user.id)
    .single();
  isAdmin = profile?.is_admin === true;
}

let timeGreeting = "Guten Tag";
try {
  const hourString = new Intl.DateTimeFormat('en-GB', { timeZone: 'Europe/Berlin', hour: 'numeric', hour12: false }).format(new Date());
  const hour = parseInt(hourString, 10);
  if (hour >= 5 && hour < 11) timeGreeting = "Guten Morgen";
  else if (hour >= 18 || hour < 5) timeGreeting = "Guten Abend";
} catch(e) {}

// We can pass user info to slots if needed via locals, or components just use their own fetches.
---

<!doctype html>
<html lang="de" class="antialiased">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="AK Kommunal WebApp" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
		<title>{title}</title>
	</head>
	<body class="bg-[#f0f2f5] text-on-background font-body h-screen overflow-hidden flex">
    
    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-[#e5e7eb] flex flex-col h-full flex-shrink-0 z-20">
      <div class="h-16 flex items-center px-4 border-b border-[#e5e7eb] pt-2">
        <BrandLogo />
      </div>
      
      <div class="flex-1 overflow-y-auto py-6 px-4 flex flex-col gap-1">
        <a href="/app/dashboard" class={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold transition-colors ${currentPath === '/app/dashboard' ? 'bg-[#05183a]/5 text-[#05183a]' : 'text-gray-500 hover:bg-gray-50 hover:text-[#05183a]'}`}>
          <span class="material-symbols-outlined text-[20px]">grid_view</span> Dashboard
        </a>
        <a href="/app/fachportal" class={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold transition-colors ${currentPath === '/app/fachportal' ? 'bg-[#05183a]/5 text-[#05183a]' : 'text-gray-500 hover:bg-gray-50 hover:text-[#05183a]'}`}>
          <span class="material-symbols-outlined text-[20px]">video_library</span> Mein Fachportal
        </a>
        <a href="/app/forum" class={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold transition-colors ${currentPath === '/app/forum' || currentPath.startsWith('/app/forum/') ? 'bg-[#05183a]/5 text-[#05183a]' : 'text-gray-500 hover:bg-gray-50 hover:text-[#05183a]'}`}>
          <span class="material-symbols-outlined text-[20px]">forum</span> Community
        </a>
        <a href="/app/profil" class={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold transition-colors ${currentPath === '/app/profil' ? 'bg-[#05183a]/5 text-[#05183a]' : 'text-gray-500 hover:bg-gray-50 hover:text-[#05183a]'}`}>
          <span class="material-symbols-outlined text-[20px]">person</span> Profil & Rechnungen
        </a>
        
        {isAdmin && (
          <>
            <div class="my-2 border-t border-gray-100"></div>
            <a href="/app/admin" class={`flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold transition-colors border ${currentPath === '/app/admin' ? 'bg-[#05183a] text-white border-[#05183a]' : 'bg-blue-50 text-blue-700 hover:bg-[#05183a] hover:text-white border-blue-200'}`}>
              <span class="material-symbols-outlined text-[20px]">admin_panel_settings</span> Administrator
            </a>
          </>
        )}
      </div>

      <div class="p-4 border-t border-[#e5e7eb]">
        <a href="/api/auth/signout" class="flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-semibold text-gray-500 hover:bg-red-50 hover:text-red-600 transition-colors">
          <span class="material-symbols-outlined text-[20px]">logout</span> Abmelden
        </a>
      </div>
    </aside>

    <!-- Main Content Area -->
    <div class="flex-1 flex flex-col h-full overflow-hidden relative">
      <!-- Topbar App -->
      <header class="h-16 bg-white border-b border-[#e5e7eb] flex items-center justify-between px-8 flex-shrink-0 z-10 w-full shadow-sm">
        <div class="flex items-center gap-4 text-gray-400">
           <span class="material-symbols-outlined cursor-pointer hover:text-[#05183a] transition-colors">menu</span>
           <span class="text-sm font-medium text-gray-800">{timeGreeting}, {displayName}</span>
        </div>
        <div class="flex items-center gap-4">

          <a href="/app/profil" title="Mein Profil & Rechnungen" class="w-10 h-10 rounded-full bg-[#05183a] text-white flex items-center justify-center font-bold text-sm shadow-md overflow-hidden border-2 border-white hover:ring-4 hover:ring-[#05183a]/10 hover:scale-105 transition-all cursor-pointer block">
            {user?.user_metadata?.avatar_url ? (
              <img src={user.user_metadata.avatar_url} class="w-full h-full object-cover">
            ) : (
              initials
            )}
          </a>
        </div>
      </header>
      
      <!-- Scrollable Content -->
      <main class="flex-1 overflow-y-auto">
        <slot />
      </main>
    </div>

    <script>
      import { clearCart } from '../store/cartStore';
      document.addEventListener('DOMContentLoaded', () => {
        const params = new URLSearchParams(window.location.search);
        if (params.has('session_id') || params.get('success') === 'invoice') {
          clearCart();
          // Optional: Clean up URL for a better experience
          window.history.replaceState({}, document.title, window.location.pathname);
        }
      });
    </script>
	</body>
</html>
<style is:global>
  ::selection {
    background-color: rgba(5,24,58,0.2);
    color: #05183a;
  }
</style>
